---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const testimonials = [
  {
    name: 'Sarah M.',
    category: 'Adult Member',
    rating: 5,
    text: 'I walked in terrified. Within weeks, I felt stronger in body and mind. The community here is real — people actually care about each other\'s progress.',
  },
  {
    name: 'James K.',
    category: 'Fight Prep',
    rating: 5,
    text: 'Joseph\'s coaching got me fight-ready. Technical depth, mental toughness, accountability. No shortcuts, just results.',
  },
  {
    name: 'Michelle L.',
    category: 'Parent',
    rating: 5,
    text: 'My son went from shy to confident. He asks to go to Stand Strong every holiday. The coaches treat the kids like human beings, not problems.',
  },
  {
    name: 'David T.',
    category: 'Beginner',
    rating: 5,
    text: 'Never trained before. Nervous as hell. First class was welcoming, fun, and I actually felt capable. Coming back this week.',
  },
  {
    name: 'Emma R.',
    category: 'Kids Program',
    rating: 5,
    text: 'Stand Strong changed how my daughter sees herself. She went from "I can\'t" to "I can handle this." Worth every moment.',
  },
  {
    name: 'Marcus P.',
    category: 'Recovery Member',
    rating: 5,
    text: 'The sauna and ice bath combo is insane. Recovery is real here. Combine that with the coaching and you\'ve got something special.',
  },
];
---

<Layout
  title="Testimonials — Soul Lab Gym"
  description="Read real reviews from Soul Lab Gym members, parents, and Stand Strong program participants. 5.0 stars with 55+ Google reviews."
>
  <Nav />

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden bg-gradient-to-br from-green-50 via-white to-pink-50">
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
      <div class="inline-block bg-pink-100 border border-pink-300 text-pink-700 text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-6">
        Real Reviews from Real Members
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-gray-900 leading-tight mb-6">
        What Our Community Says
      </h1>

      <!-- Rating Badge -->
      <div class="inline-block bg-white border-2 border-gray-200 rounded-2xl px-8 py-6 mb-8 shadow-sm hover:shadow-lg transition-shadow">
        <div class="flex items-center justify-center gap-3 mb-3">
          <div class="text-5xl font-black text-gray-900">5.0</div>
          <div class="text-3xl text-pink-500">★★★★★</div>
        </div>
        <p class="text-gray-900 text-lg font-semibold">55+ Google Reviews</p>
        <p class="text-gray-600 text-sm mt-2">Consistently rated Townsville's top Muay Thai gym</p>
      </div>

      <p class="text-xl sm:text-2xl text-gray-800 font-medium max-w-3xl mx-auto">
        Members from all backgrounds — beginners, fighters, parents, kids — share why Soul Lab Gym stands out.
      </p>
    </div>
  </section>

  <!-- PHOTO GRID + TESTIMONIALS -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-20">
        <!-- Photo collage (left) -->
        <div class="grid grid-cols-2 gap-4 h-fit">
          <div class="bg-white border-2 border-gray-200 rounded-lg overflow-hidden aspect-square group hover:shadow-lg transition-shadow">
            <img src="/photos/adult-mixed-class-2.jpg" alt="Adult training" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-lg overflow-hidden aspect-square group hover:shadow-lg transition-shadow">
            <img src="/photos/kids-guard-pose-group.jpg" alt="Kids confidence" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-lg overflow-hidden aspect-square group hover:shadow-lg transition-shadow">
            <img src="/photos/coach-pads.jpg" alt="Expert coaching" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-lg overflow-hidden aspect-square group hover:shadow-lg transition-shadow">
            <img src="/photos/team-photo.jpg" alt="Community" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
          </div>
        </div>

        <!-- Testimonials grid (right) -->
        <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-6">
          {testimonials.map(testimonial => (
            <div class="bg-white border-2 border-green-200 hover:border-pink-300 rounded-2xl p-6 transition-all hover:shadow-lg">
              <!-- Stars -->
              <div class="flex gap-1 mb-4">
                {[...Array(testimonial.rating)].map(() => (
                  <span class="text-pink-500 text-lg">★</span>
                ))}
              </div>

              <!-- Quote -->
              <p class="text-gray-700 font-medium leading-relaxed mb-6 italic">
                "{testimonial.text}"
              </p>

              <!-- Name & Category -->
              <div>
                <p class="font-bold text-gray-900">{testimonial.name}</p>
                <p class="text-sm text-pink-700 font-semibold">{testimonial.category}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- VIDEO TESTIMONIALS SECTION -->
      <div class="border-t-2 border-gray-200 pt-20">
        <h2 class="text-4xl font-black text-gray-900 text-center mb-8">Watch Real Members Tell Their Stories</h2>
        <p class="text-center text-gray-600 text-lg max-w-2xl mx-auto mb-12">
          Hear directly from members about their journey at Soul Lab Gym — from nervous beginners to confident fighters.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            { title: 'Beginner Story', desc: 'First time training — how it changed everything' },
            { title: 'Parent Perspective', desc: 'Why Stand Strong matters for our kids' },
            { title: 'Fighter\'s Journey', desc: 'From hobby to fight camp with Joseph' },
          ].map(video => (
            <div class="bg-gradient-to-br from-gray-100 to-white border-2 border-gray-200 rounded-2xl overflow-hidden group hover:shadow-lg transition-shadow">
              <div class="aspect-video bg-gray-300 flex items-center justify-center relative overflow-hidden group-hover:bg-gray-400 transition-colors">
                <div class="text-6xl text-white/50">▶</div>
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all"></div>
              </div>
              <div class="p-6">
                <h3 class="font-bold text-gray-900 mb-2">{video.title}</h3>
                <p class="text-gray-600 text-sm">{video.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="text-center mt-12">
          <p class="text-gray-600 mb-6">Video testimonials coming soon — check back or follow us on YouTube</p>
          <a href="https://www.youtube.com/channel/UCMGyz96tdBUgD-RG6SyEDRg" target="_blank" rel="noopener noreferrer" class="inline-block bg-pink-700 hover:bg-pink-800 text-white font-bold px-8 py-4 rounded-full transition-all">
            Subscribe on YouTube
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
