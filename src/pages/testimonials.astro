---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Testimonials — Soul Lab Gym"
  description="Read real reviews from Soul Lab Gym members, parents, and Stand Strong program participants. 5.0 stars with 55+ Google reviews."
>
  <Nav />

  <!-- HEADER -->
  <section class="bg-slg-dark py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-block bg-slg-pink text-white text-xs font-bold uppercase px-3 py-1 rounded-full mb-6">What People Say</div>
      <h1 class="font-display text-6xl sm:text-7xl uppercase text-white mb-4">Real Reviews</h1>
      <p class="text-white/80 text-lg max-w-2xl">
        55+ five-star Google reviews from members, parents, and fighters who trust Soul Lab Gym.
      </p>
    </div>
  </section>

  <!-- RATING BADGE -->
  <section class="bg-slg-bone py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-block bg-white border-2 border-slg-pink rounded-lg px-8 py-6 shadow-sm">
        <div class="flex items-center justify-center gap-4 mb-3">
          <div class="text-6xl font-black text-slg-text-dark">5.0</div>
          <div class="text-4xl text-pink-500">★★★★★</div>
        </div>
        <p class="text-slg-text-dark text-lg font-semibold">55+ Google Reviews</p>
        <p class="text-slg-text-dark/60 text-sm mt-2">Townsville's highest-rated Muay Thai gym</p>
      </div>
    </div>
  </section>

  <!-- GOOGLE REVIEW SCREENSHOTS -->
  <section class="py-20 bg-slg-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-block bg-slg-pink text-white text-xs font-bold uppercase px-3 py-1 rounded-full mb-6 mb-8">Member Stories</div>
      <h2 class="font-display text-5xl sm:text-6xl uppercase text-slg-text-dark mb-12">Verified Reviews</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          '/google-reviews/review-1.jpg',
          '/google-reviews/review-2.jpg',
          '/google-reviews/review-3.jpg',
          '/google-reviews/review-4.jpg',
          '/google-reviews/review-5.jpg',
          '/google-reviews/review-6.jpg',
          '/google-reviews/review-7.jpg',
          '/google-reviews/review-8.jpg',
          '/google-reviews/review-9.jpg',
          '/google-reviews/review-10.jpg',
        ].map(screenshot => (
          <div class="bg-white border-2 border-slg-pink/20 rounded overflow-hidden shadow-md hover:shadow-xl transition-shadow group">
            <img src={screenshot} alt="Google Business review" class="w-full h-auto group-hover:scale-105 transition-transform duration-300" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VIDEO TESTIMONIALS -->
  <section class="bg-slg-dark py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-block bg-slg-pink text-white text-xs font-bold uppercase px-3 py-1 rounded-full mb-6">Watch Us</div>
      <h2 class="font-display text-5xl sm:text-6xl uppercase text-white mb-4">Real Training. Real People.</h2>
      <p class="text-white/80 text-lg max-w-2xl mb-12">
        See what Soul Lab Gym is really about. These videos show the community, coaching, and transformation happening every day.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <!-- Video 1: SLG Welcome -->
        <div class="bg-black rounded overflow-hidden group hover:shadow-2xl transition-shadow">
          <div class="relative aspect-video bg-black">
            <img src="https://img.youtube.com/vi/UqR2Vhl4FRI/maxresdefault.jpg" alt="SLG Welcome" class="w-full h-full object-cover group-hover:opacity-80 transition-opacity" />
            <a href="https://youtu.be/UqR2Vhl4FRI" target="_blank" rel="noopener" class="absolute inset-0 flex items-center justify-center group-hover:bg-black/20 transition-colors">
              <svg class="w-20 h-20 text-pink-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </a>
          </div>
          <div class="p-6 bg-slg-dark border-t border-white/10">
            <h3 class="text-white font-bold text-lg mb-2">SLG Welcome</h3>
            <p class="text-white/80/70 text-sm">First look at Soul Lab Gym — meet the team and see what training is all about.</p>
          </div>
        </div>

        <!-- Video 2: Authentic Muay Thai Training -->
        <div class="bg-black rounded overflow-hidden group hover:shadow-2xl transition-shadow">
          <div class="relative aspect-video bg-black">
            <img src="https://img.youtube.com/vi/w_4j_E9VG6I/maxresdefault.jpg" alt="Authentic Muay Thai Training" class="w-full h-full object-cover group-hover:opacity-80 transition-opacity" />
            <a href="https://youtu.be/w_4j_E9VG6I" target="_blank" rel="noopener" class="absolute inset-0 flex items-center justify-center group-hover:bg-black/20 transition-colors">
              <svg class="w-20 h-20 text-pink-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </a>
          </div>
          <div class="p-6 bg-slg-dark border-t border-white/10">
            <h3 class="text-white font-bold text-lg mb-2">Authentic Muay Thai Training</h3>
            <p class="text-white/80/70 text-sm">Real training. Real technique. Real coaching from a WMO State Champion.</p>
          </div>
        </div>
      </div>

      <div class="text-center bg-white/5 border border-white/10 p-12 rounded-lg">
        <p class="text-white/80 font-semibold mb-6 text-lg">Subscribe for more</p>
        <a href="https://www.youtube.com/@soullabgym" target="_blank" rel="noopener noreferrer" class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold px-8 py-4 rounded transition-colors">
          Follow on YouTube
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
