---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const recoveryPhotos = [
  // Original 10
  { src: '/photos/recovery/Sauna-1 Exterior Full View.jpg', alt: 'Exterior view of the sauna building', title: 'Sauna Exterior' },
  { src: '/photos/recovery/Sauna-2 Interior with Rocks.jpg', alt: 'Interior of the sauna showing traditional volcanic rocks', title: 'Sauna Interior' },
  { src: '/photos/recovery/Sauna-3 Heater Detail.jpg', alt: 'Close-up of the sauna heater', title: 'Sauna Heater' },
  { src: '/photos/recovery/Sauna-4 Rocks & Equipment.jpg', alt: 'Sauna rocks and heating equipment', title: 'Sauna Details' },
  { src: '/photos/recovery/Sauna-5 Interior Full.jpg', alt: 'Wide view of the spacious sauna interior', title: 'Spacious Sauna' },
  { src: '/photos/recovery/Ice Bath -1 Full View.jpg', alt: 'Full view of the large wooden ice bath tub', title: 'Ice Bath Tub' },
  { src: '/photos/recovery/Ice Bath -2 Close Up Bubbles.jpg', alt: 'Close-up of ice bath water with bubbles', title: 'Ice Bath Close-up' },
  { src: '/photos/recovery/Ice Bath -3 with Buddha Statue.jpg', alt: 'Ice bath with peaceful Buddha statue beside it', title: 'Peaceful Ice Bath' },
  { src: '/photos/recovery/Ice Bath -4 Exterior View.jpg', alt: 'Ice bath viewed from outside the recovery studio', title: 'Ice Bath Exterior' },
  { src: '/photos/recovery/Sauna + Ice Bath Facility Overview.jpg', alt: 'Overview of the entire sauna and ice bath recovery facility', title: 'Full Recovery Set' },

  // New 4 photos (just received)
  { src: '/photos/recovery/ice-bath-buddha-calm.jpg', alt: 'Ice bath tub with Buddha statue on the left in calm pose', title: 'Ice Bath + Buddha Calm' },
  { src: '/photos/recovery/ice-bath-buddha-side.jpg', alt: 'Side angle of the ice bath with Buddha statue', title: 'Ice Bath + Buddha Angled' },
  { src: '/photos/recovery/recovery-shelf-green-hat.jpg', alt: 'Recovery studio accessories shelf including traditional green sauna hat, Ganesha statue and other decor', title: 'Recovery Studio Details' },
  { src: '/photos/recovery/ice-bath-buddha-outdoor.jpg', alt: 'Ice bath with Buddha statue in front of the open studio door looking outside', title: 'Ice Bath View to Outside' },
];
---

<Layout
  title="Soul Lab Recovery — Sauna & Ice Bath Services in Townsville"
  description="Premium sauna and ice bath recovery services in Townsville. Single sessions, 5-session packages, or unlimited monthly membership."
>
  <Nav />

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
    <div class="absolute inset-0">
      <img 
        src="/photos/recovery/Sauna + Ice Bath Facility Overview.jpg" 
        alt="Full recovery facility overview" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/25 to-black/50"></div>
    </div>
    
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
      <div class="inline-block bg-slg-bone/90 backdrop-blur-sm border border-slg-pink text-slg-pink text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded mb-6">
        Recovery Services • Soul Lab Gym
      </div>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white drop-shadow mb-4">
        Recover Faster.<br>
        <span class="bg-slg-pink bg-clip-text text-white">Feel Better.</span>
      </h1>
      <p class="text-xl sm:text-2xl text-white font-medium mb-8 max-w-2xl mx-auto drop-shadow">
        Premium sauna and ice bath recovery services in Townsville.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://slg.gymdesk.com/login"
          class="bg-slg-pink hover:bg-slg-pink text-white font-bold text-base px-8 py-4 rounded transition-all shadow-lg"
        >
          Book Your First Session
        </a>
        <a
          href="#pricing"
          class="bg-slg-bone/95 hover:bg-slg-bone font-display uppercase font-bold text-base px-8 py-4 rounded transition-all border border-white/30 shadow"
        >
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <!-- OUR RECOVERY STUDIO - All 14 photos -->
  <section id="facility" class="py-20 bg-slg-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="inline-block bg-slg-bone border border-slg-pink text-slg-pink text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded mb-3">
          Our Recovery Studio
        </div>
        <h2 class="text-4xl font-display uppercase font-display uppercase mb-4">Purpose-Built for Real Results</h2>
        <p class="text-lg text-[#1A1A1A] !important max-w-2xl mx-auto">
          Clean, private, and fully equipped. Everything you need for serious recovery — sauna heat, ice-cold contrast, and calm.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {recoveryPhotos.map((photo, idx) => (
          <div 
            class="group relative overflow-hidden rounded-none aspect-[4/3] cursor-pointer border-2 border-gray-200 hover:border-slg-pink shadow-sm hover:shadow-lg transition-all"
            onclick={`openPhotoLightbox(${idx})`}
          >
            <img 
              src={photo.src} 
              alt={photo.alt} 
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <p class="text-white font-semibold text-lg drop-shadow">{photo.title}</p>
            </div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
              <span class="bg-slg-bone/90 px-3 py-1 rounded text-xs font-bold font-display uppercase shadow">View larger</span>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-8 text-sm text-[#1A1A1A] !important">
        Click any photo for a closer look.
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-20 bg-slg-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-12">
        <h2 class="text-4xl font-display uppercase font-display uppercase mb-6">Why Recovery Matters</h2>
        <p class="text-lg text-[#1A1A1A] !important leading-relaxed mb-4">
          Sauna and ice bath therapy are time-tested recovery modalities used by elite athletes, fighters, and wellness-focused individuals. The contrast between heat and cold triggers powerful adaptations in your nervous system, circulation, and recovery capacity.
        </p>
        <p class="text-lg text-[#1A1A1A] !important leading-relaxed">
          At Soul Lab Recovery, we provide a controlled, safe environment to experience these benefits with expert guidance.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-slg-bone border-2 border-slg-pink/30 rounded-none p-8 hover:shadow-lg transition-all">
          <h3 class="text-xl font-bold font-display uppercase mb-3">Faster Recovery</h3>
          <p class="text-[#1A1A1A] !important">Reduce muscle soreness, accelerate healing, and bounce back from intense training sessions in half the time.</p>
        </div>

        <div class="bg-slg-bone border-2 border-slg-pink/30 rounded-none p-8 hover:shadow-lg transition-all">
          <h3 class="text-xl font-bold font-display uppercase mb-3">Mental Clarity</h3>
          <p class="text-[#1A1A1A] !important">Reset your nervous system, reduce stress, and experience the mental edge that comes from deliberate recovery.</p>
        </div>

        <div class="bg-slg-bone border-2 border-slg-pink/30 rounded-none p-8 hover:shadow-lg transition-all">
          <h3 class="text-xl font-bold font-display uppercase mb-3">Immune Boost</h3>
          <p class="text-[#1A1A1A] !important">Strengthen immune resilience through heat shock proteins and improved circulation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BENEFITS -->
  <section id="benefits" class="py-16 bg-gray-50 border-t border-b">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-10">
        <h2 class="text-3xl font-display uppercase font-display uppercase mb-3">Why Athletes & Wellness Enthusiasts Choose Soul Lab Recovery</h2>
        <p class="text-lg text-[#1A1A1A] !important">Professional equipment. Real guidance. Flexible access.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        {[
          ['Professional-Grade Equipment', 'Commercial-quality sauna and ice bath facilities designed for serious recovery.'],
          ['Expert Guidance', 'Our team understands the science and will help you get the most from each session.'],
          ['Flexible Membership', 'Drop-in sessions or commitment-free packages. Choose what works for you.'],
          ['Community Focused', 'Part of the Soul Lab family. Recover alongside serious athletes and wellness enthusiasts.'],
        ].map(([title, desc]) => (
          <div class="bg-slg-bone border border-gray-200 rounded-none p-6 flex gap-4">
            <div class="flex-shrink-0">
              <div class="w-9 h-9 rounded bg-gradient-to-r from-pink-500 to-slg-bone flex items-center justify-center text-white text-lg">✓</div>
            </div>
            <div>
              <h4 class="font-bold text-lg font-display uppercase mb-1">{title}</h4>
              <p class="text-[#1A1A1A] !important text-sm leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section id="pricing" class="py-20 bg-slg-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-display uppercase font-display uppercase mb-4">Pricing Plans</h2>
        <p class="text-xl text-[#1A1A1A] !important">Choose the plan that fits your recovery goals.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <!-- Single -->
        <div class="border-2 border-gray-200 rounded-none p-8 hover:shadow-lg hover:border-slg-pink transition-all bg-slg-bone">
          <h3 class="text-3xl font-black font-display uppercase mb-1">Single Session</h3>
          <div class="mb-6">
            <span class="text-4xl font-black text-slg-pink">$35</span>
            <span class="text-[#1A1A1A] !important ml-1">/ session</span>
          </div>
          <ul class="space-y-3 mb-8 text-[#1A1A1A] !important text-[15px]">
            <li class="flex items-start gap-2"><span class="text-pink-500 font-bold mt-0.5">✓</span> Sauna + Ice Bath combo</li>
            <li class="flex items-start gap-2"><span class="text-pink-500 font-bold mt-0.5">✓</span> 30-minute session</li>
            <li class="flex items-start gap-2"><span class="text-pink-500 font-bold mt-0.5">✓</span> Expert guidance included</li>
          </ul>
          <a href="https://slg.gymdesk.com/login" class="block text-center bg-gray-900 hover:bg-black text-white font-bold py-3 rounded transition-colors">Book Now</a>
        </div>

        <!-- 5-Pack -->
        <div class="border-4 border-emerald-400 rounded-none p-8 relative shadow-[0_10px_40px_rgb(16,185,129,0.08)] bg-slg-bone">
          <div class="absolute -top-3 left-9 bg-emerald-500 text-white font-bold px-4 py-0.5 rounded shadow text-sm">BEST VALUE</div>
          <h3 class="text-3xl font-black font-display uppercase mb-1">5-Session Package</h3>
          <div class="mb-6">
            <span class="text-4xl font-black text-slg-pink">$150</span>
            <span class="text-[#1A1A1A] !important ml-1 text-base">($30 per session)</span>
          </div>
          <ul class="space-y-3 mb-8 text-[#1A1A1A] !important text-[15px]">
            <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold mt-0.5">✓</span> 5 × 30-minute sessions</li>
            <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold mt-0.5">✓</span> Save $25 vs single sessions</li>
            <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold mt-0.5">✓</span> Valid for 3 months</li>
            <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold mt-0.5">✓</span> Expert guidance included</li>
          </ul>
          <a href="https://slg.gymdesk.com/login" class="block text-center bg-gradient-to-r from-emerald-500 to-slg-bone hover:from-emerald-600 hover:to-slg-bone0 text-white font-bold py-3 rounded transition-all">Get Package</a>
        </div>

        <!-- Unlimited -->
        <div class="border-2 border-gray-200 rounded-none p-8 hover:shadow-lg hover:border-slg-pink transition-all bg-slg-bone">
          <h3 class="text-3xl font-black font-display uppercase mb-1">Monthly Unlimited</h3>
          <div class="mb-6">
            <span class="text-4xl font-black text-slg-pink">$89</span>
            <span class="text-[#1A1A1A] !important ml-1">/ month</span>
          </div>
          <ul class="space-y-3 mb-8 text-[#1A1A1A] !important text-[15px]">
            <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold mt-0.5">✓</span> Unlimited sessions</li>
            <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold mt-0.5">✓</span> Perfect for regulars</li>
            <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold mt-0.5">✓</span> 30-minute sessions</li>
            <li class="flex items-start gap-2"><span class="text-emerald-500 font-bold mt-0.5">✓</span> Expert guidance included</li>
          </ul>
          <a href="https://slg.gymdesk.com/login" class="block text-center bg-slg-pink hover:bg-slg-pink text-white font-bold py-3 rounded transition-all">Subscribe</a>
        </div>
      </div>

      <div class="mt-6 bg-emerald-50 border border-emerald-200 rounded-none p-5 text-center">
        <p class="text-emerald-800 font-medium">
          Soul Lab Gym Members save <span class="font-black">15%</span> on all recovery packages. Ask at the desk for your code.
        </p>
      </div>
    </div>
  </section>

  <!-- VIDEO PLACEHOLDER -->
  <section id="watch" class="py-20 bg-slg-bone">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <div class="inline px-4 py-1 text-xs font-bold tracking-wider text-slg-pink bg-slg-bone border border-slg-pink/30 rounded">See It In Action</div>
        <h2 class="text-4xl font-display uppercase font-display uppercase mt-3">Watch a Real Recovery Session</h2>
        <p class="max-w-xl mx-auto mt-3 text-[#1A1A1A] !important">Short clip showing the flow — heat, cold, reset.</p>
      </div>
      
      <div class="relative w-full max-w-4xl mx-auto aspect-video overflow-hidden rounded-3xl shadow-xl border border-gray-200">
        <iframe 
          class="w-full h-full"
          src="https://www.youtube.com/embed/0-iS-bgq5c4" 
          title="Stop Destroying Your Legs: 3 Essential Muay Thai Defences - Soul Lab Gym" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
          allowfullscreen
        ></iframe>
      </div>
      <p class="text-center text-sm text-[#1A1A1A] !important mt-4">
        Real technique from the mats at Soul Lab. Watch more full sessions and recovery tips on our <a href="https://www.youtube.com/@soullabgym" target="_blank" class="font-semibold text-slg-pink hover:text-slg-pink underline">YouTube channel</a>.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-slg-bone">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-display uppercase font-display uppercase mb-10 text-center">Frequently Asked Questions</h2>

      <div class="space-y-3">
        <details class="group bg-slg-bone border-2 border-gray-100 rounded-none p-6 open:bg-slg-bone/30 transition-all">
          <summary class="font-bold text-lg flex items-center justify-between cursor-pointer font-display uppercase">
            How hot is the sauna?
            <span class="text-slg-pink group-open:rotate-180 transition">▼</span>
          </summary>
          <p class="mt-4 text-[#1A1A1A] !important">160–180°F (70–82°C). This range gives real physiological benefits while staying comfortable and safe for most people.</p>
        </details>

        <details class="group bg-slg-bone border-2 border-gray-100 rounded-none p-6 open:bg-slg-bone/30 transition-all">
          <summary class="font-bold text-lg flex items-center justify-between cursor-pointer font-display uppercase">
            Is ice bath exposure dangerous?
            <span class="text-slg-pink group-open:rotate-180 transition">▼</span>
          </summary>
          <p class="mt-4 text-[#1A1A1A] !important">No. We use 50–60°F (10–15°C) water. Sessions are guided, we teach proper breathing, and we adjust based on your experience level. Cardiovascular consult recommended if you have heart concerns.</p>
        </details>

        <details class="group bg-slg-bone border-2 border-gray-100 rounded-none p-6 open:bg-slg-bone/30 transition-all">
          <summary class="font-bold text-lg flex items-center justify-between cursor-pointer font-display uppercase">
            I’ve never done this before — is it beginner friendly?
            <span class="text-slg-pink group-open:rotate-180 transition">▼</span>
          </summary>
          <p class="mt-4 text-[#1A1A1A] !important">Absolutely. Beginners start with shorter times and we walk you through breathing and timing. No prior experience needed.</p>
        </details>

        <details class="group bg-slg-bone border-2 border-gray-100 rounded-none p-6 open:bg-slg-bone/30 transition-all">
          <summary class="font-bold text-lg flex items-center justify-between cursor-pointer font-display uppercase">
            How long is a typical session?
            <span class="text-slg-pink group-open:rotate-180 transition">▼</span>
          </summary>
          <p class="mt-4 text-[#1A1A1A] !important">Plan 45–60 minutes total: 15–20 min sauna, 2–3 min ice bath, plus rest.</p>
        </details>

        <details class="group bg-slg-bone border-2 border-gray-100 rounded-none p-6 open:bg-slg-bone/30 transition-all">
          <summary class="font-bold text-lg flex items-center justify-between cursor-pointer font-display uppercase">
            Can I use this right after a workout?
            <span class="text-slg-pink group-open:rotate-180 transition">▼</span>
          </summary>
          <p class="mt-4 text-[#1A1A1A] !important">Yes. Many people do their recovery session 10–30 minutes after training. It's one of the best times for contrast therapy.</p>
        </details>
      </div>
    </div>
  </section>

  <Footer />

  <!-- LIGHTBOX -->
  <div 
    id="photo-lightbox" 
    onclick="closeLightbox()" 
    class="hidden fixed inset-0 z-[999] bg-black/95 flex items-center justify-center p-6 cursor-pointer"
  >
    <button 
      onclick="event.stopImmediatePropagation(); closeLightbox()" 
      class="absolute top-6 right-6 text-white text-4xl hover:text-pink-400 z-[1001] font-light"
    >
      ✕
    </button>
    
    <div onclick="event.stopImmediatePropagation()" class="max-w-6xl w-full">
      <img id="lightbox-img" class="max-h-[82vh] mx-auto rounded-3xl shadow-2xl border border-white/10" src="" alt="" />
      <p id="lightbox-caption" class="text-center text-white text-2xl font-semibold mt-5 tracking-tight"></p>
    </div>
  </div>
</Layout>

<script>
  const recoveryPhotos = {recoveryPhotos};

  function openPhotoLightbox(index) {
    const modal = document.getElementById('photo-lightbox');
    const img = document.getElementById('lightbox-img');
    const caption = document.getElementById('lightbox-caption');
    if (!modal || !img || !caption) return;

    const photo = recoveryPhotos[index];
    img.src = photo.src;
    img.alt = photo.alt;
    caption.textContent = photo.title;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    const modal = document.getElementById('photo-lightbox');
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  document.addEventListener('keydown', (e) => {
    const modal = document.getElementById('photo-lightbox');
    if (modal && !modal.classList.contains('hidden') && e.key === 'Escape') {
      closeLightbox();
    }
  });
</script>
