---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Timetable — Soul Lab Gym"
  description="Soul Lab Gym class timetable. Muay Thai, Boxing, Kids classes in Townsville. Book your session today."
>
  <Nav />

  <div class="pt-16">
    <!-- PAGE HEADER -->
    <section class="py-20 bg-slg-bone">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-5xl sm:text-6xl font-display text-gray-900 mb-6">
          Class <span class="text-pink-500">Timetable</span>
        </h1>
        <p class="text-gray-700 text-lg leading-relaxed max-w-2xl mx-auto">
          Pick the classes that fit your goals. Whether you're building foundations, keeping the fight team sharp, or booking kids sessions, our live schedule updates in real time.
        </p>
      </div>
    </section>

    <!-- CLASS LEVELS -->
    <section class="py-16 bg-gradient-to-b from-slg-bone to-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-black text-gray-900 mb-8 text-center">Class Levels</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
          <!-- Level 1 -->
          <div class="bg-white border-2 border-slg-pink/30 rounded-xl p-8 hover:shadow-lg transition-shadow">
            <div class="flex items-center gap-3 mb-4">
              <span class="bg-slg-bone border border-slg-pink/30 text-slg-text-dark text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">Level 1</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Foundations</h3>
            <p class="text-gray-700 leading-relaxed">Ideal for beginners and returning members. Learn stance, basic strikes, defense, and pad etiquette with plenty of coaching.</p>
          </div>

          <!-- Level 2 -->
          <div class="bg-white border-2 border-pink-200 rounded-xl p-8 hover:shadow-lg transition-shadow">
            <div class="flex items-center gap-3 mb-4">
              <span class="bg-slg-bone border border-slg-pink text-slg-pink text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">Level 2</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Intermediate / All Levels</h3>
            <p class="text-gray-700 leading-relaxed">Technique-driven sessions with pad rounds, partner drills, and conditioning. Perfect for students who know the basics and want to build ring IQ.</p>
          </div>

          <!-- Level 3 -->
          <div class="bg-white border-2 border-blue-200 rounded-xl p-8 hover:shadow-lg transition-shadow">
            <div class="flex items-center gap-3 mb-4">
              <span class="bg-slg-bone border border-slg-pink text-slg-pink text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">Level 3 — Invite Only</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">Fighters / Advanced</h3>
            <p class="text-gray-700 leading-relaxed">Invitation-only training blocks for fighters and advanced students. Expect sparring, clinch, and fight camp preparation.</p>
          </div>
        </div>

        <!-- GYMDESK EMBED -->
        <div class="mt-4">
          <h2 class="text-2xl font-black text-gray-900 mb-6 text-center">Live Schedule</h2>
          <div class="bg-white border-2 border-slg-pink/30 rounded-2xl p-8">
            <div id="gymdesk-widget" class="gymdesk-schedule" attr-gym="DLVb1" attr-visible_schedule="all" attr-default_schedule="all"></div>
          </div>
        </div>

        <script>
          // Initialize Gymdesk widget after page loads
          document.addEventListener('DOMContentLoaded', function() {
            if (window.GymDeskWidgets) {
              window.GymDeskWidgets.initAll();
            }
          });
          
          // Also try to init when script loads
          if (window.GymDeskWidgets) {
            window.GymDeskWidgets.initAll();
          }
        </script>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-slg-bone">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-display uppercase text-gray-900 mb-4">Ready to jump in?</h2>
        <p class="text-gray-700 mb-8">Claim your 7-day trial and attend unlimited classes this week.</p>
        <a
          href="https://slg.gymdesk.com/signup"
          class="inline-block bg-slg-pink hover:bg-slg-pink text-white font-bold text-base px-8 py-4 rounded-full transition-all shadow-lg"
        >
          Claim Your 7-Day Pass
        </a>
      </div>
    </section>
  </div>

  <Footer />
</Layout>
