---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Timetable — Soul Lab Gym"
  description="Soul Lab Gym class timetable. Muay Thai, Boxing, Kids classes in Townsville. Book your session today."
>
  <Nav />

  <div class="pt-16">
    <!-- PAGE HEADER -->
    <section class="py-20 bg-slg-bone">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-5xl sm:text-6xl font-display text-slg-text-dark mb-6">
          Class <span class="text-slg-pink">Timetable</span>
        </h1>
        <p class="text-slg-text-dark text-lg leading-relaxed max-w-2xl mx-auto">
          Pick the classes that fit your goals. Whether you're building foundations, keeping the fight team sharp, or booking kids sessions, our live schedule updates in real time.
        </p>
      </div>
    </section>

    <!-- CLASS LEVELS -->
    <section class="py-16 bg-slg-bone">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-display uppercase text-slg-text-dark mb-8 text-center">All Levels Welcome</h2>
        <div class="max-w-2xl mx-auto mb-16">
          <div class="bg-slg-dark border-l-4 border-slg-pink p-10">
            <span class="text-slg-pink text-xs font-bold uppercase tracking-widest">All Levels</span>
            <h3 class="text-2xl font-display uppercase text-white mt-2 mb-4">Every Class, Every Level</h3>
            <p class="text-slg-text-light leading-relaxed mb-6">Whether it's your first session or your hundredth, you belong in the same class. Our coaches scale every session to meet you where you're at — beginners train alongside experienced members and everyone moves forward together.</p>
            <ul class="space-y-3">
              <li class="flex gap-3 text-slg-text-light/80 text-sm"><span class="text-slg-pink font-bold">→</span> Complete beginners welcome every session</li>
              <li class="flex gap-3 text-slg-text-light/80 text-sm"><span class="text-slg-pink font-bold">→</span> Coaches adapt the session to your level</li>
              <li class="flex gap-3 text-slg-text-light/80 text-sm"><span class="text-slg-pink font-bold">→</span> No experience needed — just show up</li>
              <li class="flex gap-3 text-slg-text-light/80 text-sm"><span class="text-slg-pink font-bold">→</span> Loaner gear available for your first session</li>
            </ul>
          </div>
        </div>

        <!-- GYMDESK EMBED -->
        <div class="mt-4">
          <h2 class="text-2xl font-black text-slg-text-dark mb-6 text-center">Live Schedule</h2>
          <div class="bg-slg-bone border-2 border-slg-pink/30 rounded-none p-8">
            <div id="gymdesk-widget" class="gymdesk-schedule" attr-gym="DLVb1" attr-visible_schedule="all" attr-default_schedule="all"></div>
          </div>
        </div>

        <script>
          // Initialize Gymdesk widget after page loads
          document.addEventListener('DOMContentLoaded', function() {
            if (window.GymDeskWidgets) {
              window.GymDeskWidgets.initAll();
            }
          });
          
          // Also try to init when script loads
          if (window.GymDeskWidgets) {
            window.GymDeskWidgets.initAll();
          }
        </script>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-slg-bone">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-display uppercase text-slg-text-dark mb-4">Ready to jump in?</h2>
        <p class="text-slg-text-dark mb-8">Claim your free trial and attend unlimited classes — plus get a free gear pack when you sign up.</p>
        <a
          href="https://soullabgymoffer.com/offer"
          class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-8 py-4 transition-colors""
        >
          Claim Free Trial + Gear Pack
        </a>
      </div>
    </section>
  </div>

  <Footer />
</Layout>
