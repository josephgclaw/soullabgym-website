---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact — Soul Lab Gym"
  description="Get in touch with Soul Lab Gym. Call, email, or visit us at 2/70 Ingham Road, West End, Townsville QLD."
>
  <Nav />

  <div class="pt-16">
    <!-- PAGE HEADER -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-5xl sm:text-6xl font-black text-gray-900 mb-4">
          Get In <span class="text-pink-500">Touch</span>
        </h1>
        <p class="text-gray-700 text-lg max-w-xl mx-auto">
          Get in contact and one of our friendly staff will get back to you within 24 hours.
        </p>
      </div>
    </section>

    <!-- CONTACT DETAILS + FREE TRIAL -->
    <section class="py-16 bg-gradient-to-b from-green-50 to-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
          <!-- Contact Info -->
          <div class="bg-white border-2 border-green-200 rounded-xl p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-8">Contact Details</h2>
            <div class="flex flex-col gap-6">
              <a
                href="tel:0432558304"
                class="flex items-center gap-4 p-4 bg-gradient-to-b from-green-50 to-white border-2 border-green-200 hover:border-pink-300 rounded-lg transition-colors group"
              >
                <div>
                  <div class="text-xs text-gray-600 uppercase tracking-wider mb-1">Phone</div>
                  <div class="text-gray-900 font-semibold group-hover:text-pink-500 transition-colors">0432 558 304</div>
                </div>
              </a>
              <a
                href="mailto:info@soullabgym.com"
                class="flex items-center gap-4 p-4 bg-gradient-to-b from-green-50 to-white border-2 border-green-200 hover:border-pink-300 rounded-lg transition-colors group"
              >
                <div>
                  <div class="text-xs text-gray-600 uppercase tracking-wider mb-1">Email</div>
                  <div class="text-gray-900 font-semibold group-hover:text-pink-500 transition-colors">info@soullabgym.com</div>
                </div>
              </a>
              <div class="flex items-center gap-4 p-4 bg-gradient-to-b from-green-50 to-white border-2 border-green-200 rounded-lg">
                <div>
                  <div class="text-xs text-gray-600 uppercase tracking-wider mb-1">Address</div>
                  <div class="text-gray-900 font-semibold">2/70 Ingham Road</div>
                  <div class="text-gray-700 text-sm">West End, Townsville QLD</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Free Trial Card -->
          <div class="bg-gradient-to-br from-green-50 to-pink-50 border-2 border-green-200 rounded-xl p-8">
            <div class="inline-block bg-pink-100 text-pink-700 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-6">
              Free Trial
            </div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Never trained before?</h2>
            <p class="text-gray-700 leading-relaxed mb-8">
              Come try a class on us. No commitment, no pressure — just real Muay Thai, real people.
            </p>
            <div class="flex flex-col gap-4 mb-8">
              <div class="flex items-start gap-3">
                <span class="text-pink-500 font-bold mt-0.5">✓</span>
                <span><strong class="text-gray-900">For adults:</strong> Includes a free pair of gloves</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-pink-500 font-bold mt-0.5">✓</span>
                <span><strong class="text-gray-900">For kids:</strong> Includes gloves and a singlet</span>
              </div>
            </div>
            <a
              href="https://slg.gymdesk.com/signup"
              class="inline-block bg-gradient-to-r from-pink-500 to-green-400 hover:from-pink-600 hover:to-green-500 text-white font-bold text-base px-8 py-4 rounded-full transition-all shadow-lg w-full text-center"
            >
              Claim Your Free Trial
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- MAP -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-8">
          <h2 class="text-3xl font-black text-gray-900 mb-3">Visit Us</h2>
          <p class="text-gray-600">We're located at 2/70 Ingham Road, West End — easy to find, plenty of parking.</p>
          <p class="text-gray-700 mt-2">Just show up in comfortable workout gear and we'll sort the rest.</p>
        </div>
        <!-- TODO: Add Google Maps embed -->
        <div class="bg-white border-2 border-gray-200 rounded-xl overflow-hidden h-80 flex items-center justify-center text-gray-500">
          <div class="text-center">
            <p class="font-semibold text-gray-900">2/70 Ingham Road, West End, Townsville QLD</p>
            <p class="text-sm mt-2 text-gray-600">Google Maps embed coming soon</p>
          </div>
        </div>
      </div>
    </section>
  </div>

  <Footer />
</Layout>
