---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact — Soul Lab Gym"
  description="Get in touch with Soul Lab Gym. Call, email, or visit us at 2/70 Ingham Road, West End, Townsville QLD."
>
  <Nav />

  <!-- PAGE HEADER -->
  <section style="background-color: #0E0E0E !important;" class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div style="background-color: #EC4899 !important; color: #ffffff !important;" class="inline-block text-xs font-bold uppercase px-3 py-1 rounded-full mb-6">Contact Us</div>
      <h1 style="color: #ffffff !important;" class="text-5xl sm:text-6xl font-display uppercase mb-6">
        Get In Touch
      </h1>
      <p style="color: #ffffff !important;" class="text-lg leading-relaxed max-w-2xl">
        We're here to help. Questions about our programs, booking a trial, or just want to say hi? Contact us.
      </p>
    </div>
  </section>

  <!-- CONTACT DETAILS -->
  <section style="background-color: #F8F5F0 !important;" class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Info -->
        <div>
          <h2 style="color: #1A1A1A !important;" class="text-3xl font-display uppercase mb-8">Soul Lab Gym</h2>
          
          <div class="space-y-8">
            <div>
              <h3 style="color: #EC4899 !important;" class="font-bold text-lg mb-2">Location</h3>
              <p style="color: #1A1A1A !important;" class="text-lg">
                2/70 Ingham Road<br />
                West End, QLD 4810<br />
                Australia
              </p>
            </div>

            <div>
              <h3 style="color: #EC4899 !important;" class="font-bold text-lg mb-2">Phone</h3>
              <p style="color: #1A1A1A !important;" class="text-lg">
                <a href="tel:0432558304" class="hover:underline">0432 558 304</a>
              </p>
            </div>

            <div>
              <h3 style="color: #EC4899 !important;" class="font-bold text-lg mb-2">Email</h3>
              <p style="color: #1A1A1A !important;" class="text-lg">
                <a href="mailto:info@soullabgym.com" class="hover:underline">info@soullabgym.com</a>
              </p>
            </div>

            <div>
              <h3 style="color: #EC4899 !important;" class="font-bold text-lg mb-2">Hours</h3>
              <p style="color: #1A1A1A !important;" class="text-lg">
                Monday–Friday: 4 PM – 9 PM<br />
                Saturday: 10 AM – 5 PM<br />
                Sunday: Closed
              </p>
            </div>
          </div>
        </div>

        <!-- Photos -->
        <div class="grid grid-cols-2 gap-4">
          <img src="/photos/gym-wide-shot.jpg" alt="Gym" class="w-full h-48 object-cover" />
          <img src="/photos/joseph-kids-hero.jpg" alt="Joseph coaching" class="w-full h-48 object-cover" />
          <img src="/photos/team-photo.jpg" alt="Team" class="w-full h-48 object-cover" />
          <img src="/photos/kids-with-coach.jpg" alt="Kids with coach" class="w-full h-48 object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- FREE TRIAL CTA -->
  <section style="background-color: #EC4899 !important;" class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 style="color: #ffffff !important;" class="text-3xl sm:text-4xl font-display uppercase mb-6">Ready to Train?</h2>
      <p style="color: rgba(255, 255, 255, 0.9) !important;" class="text-lg mb-8 max-w-2xl mx-auto">
        Start your free trial today and get a free gear pack on signup. No commitment, no credit card.
      </p>
      <a
        href="https://slg.gymdesk.com/signup"
        style="background-color: #0E0E0E !important; color: #ffffff !important; display: inline-block; padding: 1rem 2rem; font-weight: bold; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; border-radius: 0.25rem;"
      >
        Claim Free Trial
      </a>
    </div>
  </section>

  <Footer />
</Layout>
