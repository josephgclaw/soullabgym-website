---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact — Soul Lab Gym"
  description="Get in touch with Soul Lab Gym. Call, email, or visit us at 2/70 Ingham Road, West End, Townsville QLD."
>
  <Nav />

  <!-- PAGE HEADER -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-8 py-4 transition-colors" class="inline-block text-xs font-bold uppercase px-3 py-1 mb-6">Contact Us</div>
      <h1 class="text-5xl sm:text-6xl font-display uppercase mb-6">
        Get In Touch
      </h1>
      <p class="text-lg leading-relaxed max-w-2xl">
        We're here to help. Questions about our programs, booking a trial, or just want to say hi? Contact us.
      </p>
    </div>
  </section>

  <!-- CONTACT DETAILS -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Info -->
        <div>
          <h2 class="text-3xl font-display uppercase text-slg-text-dark mb-8">Soul Lab Gym</h2>
          
          <div class="space-y-8">
            <div>
              <h3 class="text-slg-pink font-bold text-lg mb-2">Location</h3>
              <p class="text-slg-text-dark text-lg">
                2/70 Ingham Road<br />
                West End, QLD 4810<br />
                Australia
              </p>
            </div>

            <div>
              <h3 class="text-slg-pink font-bold text-lg mb-2">Phone</h3>
              <p class="text-lg">
                <a href="tel:0432558304" class="text-slg-text-dark hover:text-slg-pink transition-colors">0432 558 304</a>
              </p>
            </div>

            <div>
              <h3 class="text-slg-pink font-bold text-lg mb-2">Email</h3>
              <p class="text-lg">
                <a href="mailto:soullabgym@gmail.com" class="text-slg-text-dark hover:text-slg-pink transition-colors">soullabgym@gmail.com</a>
              </p>
            </div>

            <div>
              <h3 class="text-slg-pink font-bold text-lg mb-2">Hours</h3>
              <p class="text-slg-text-dark text-lg">
                Monday–Friday: 4 PM – 9 PM<br />
                Saturday: 10 AM – 5 PM<br />
                Sunday: Closed
              </p>
            </div>
          </div>
        </div>

        <!-- Photos -->
        <div class="grid grid-cols-2 gap-4">
          <img src="/photos/gym-wide-shot.jpg" alt="Gym" class="w-full h-48 object-cover" />
          <img src="/photos/joseph-kids-hero.jpg" alt="Joseph coaching" class="w-full h-48 object-cover" />
          <img src="/photos/team-photo.jpg" alt="Team" class="w-full h-48 object-cover" />
          <img src="/photos/kids-with-coach.jpg" alt="Kids with coach" class="w-full h-48 object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- FREE TRIAL CTA -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-display uppercase text-white mb-6">Ready to Train?</h2>
      <p class="text-lg mb-8 max-w-2xl mx-auto">
        Start your free trial today and get a free gear pack on signup. No commitment, no credit card.
      </p>
      <a
        href="https://soullabgymoffer.com/offer"
        class="inline-block bg-slg-dark hover:bg-slg-text-dark text-white font-bold text-sm uppercase tracking-wide px-8 py-4 transition-colors"
      >
        Claim Free Trial + Gear Pack
      </a>
    </div>
  </section>

  <Footer />
</Layout>
