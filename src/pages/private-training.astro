---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Private Training — Soul Lab Gym"
  description="One-on-one Muay Thai coaching in Townsville. Personalised private training sessions with Joseph Gabiola or senior Soul Lab coaches."
>
  <Nav />

  <div class="pt-16">
    <!-- HERO SECTION WITH PHOTOS -->
    <section class="py-20 bg-slg-bone">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <!-- Left: Text -->
          <div>
            <div class="inline-block bg-slg-pink text-white text-xs font-semibold uppercase tracking-widest px-4 py-2 mb-6">
              One-on-One Coaching
            </div>
            <h1 class="text-5xl sm:text-6xl font-display uppercase text-slg-text-dark mb-6">
              Private Training Tailored to You
            </h1>
            <p class="text-xl text-slg-text-dark leading-relaxed mb-6">
              Whether you're preparing for a fight, recovering from injury, building a solid foundation, or want focused technique work — private sessions give you the coach's full attention and a plan that's 100% yours.
            </p>
            <p class="text-slg-text-dark text-lg mb-8">
              Train with Joseph (WMO State Champion) or one of our senior Soul Lab coaches. Flexible scheduling. Real results.
            </p>
            <a
              href="#booking"
              class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-8 py-4 transition-colors""
            >
              Book Your Session Now
            </a>
          </div>

          <!-- Right: Photo grid -->
          <div class="grid grid-cols-2 gap-4">
            <div class="overflow-hidden aspect-square group">
              <img src="/photos/coach-pads.jpg" alt="Personalized coaching" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
            </div>
            <div class="overflow-hidden aspect-square group">
              <img src="/photos/joseph-kids-hero.jpg" alt="Joseph coaching" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
            </div>
            <div class="overflow-hidden aspect-square group">
              <img src="/photos/training-women-pad-work.jpg" alt="Technique work" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
            </div>
            <div class="overflow-hidden aspect-square group">
              <img src="/photos/pad-work-sparring.jpg" alt="Advanced training" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BOOKING SECTION (early, high visibility) -->
    <section id="booking" class="py-20 bg-slg-dark">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-4xl font-display uppercase text-white mb-3">Book a Session</h2>
          <p class="text-slg-text-light/70 text-lg">
            30-minute private session — <span class="text-slg-pink font-bold">$50</span> · Buy 5 or more — <span class="text-slg-pink font-bold">$40 each</span>
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <!-- Widget -->
          <div class="bg-white p-6">
            <iframe src="https://go.ziplinks.com.au/widget/booking/1qa6SnkbDyWZD8NwtVCB" style="width: 100%;border:none;overflow: hidden;" scrolling="no" id="H8vOqDBDHMtPrB6D4nyg_1781356764313"></iframe>
            <script src="https://go.ziplinks.com.au/js/form_embed.js" type="text/javascript"></script>
          </div>

          <!-- Contact sidebar -->
          <div class="space-y-6">
            <div class="bg-slg-bone border-l-4 border-slg-pink p-8">
              <h3 class="text-lg font-display uppercase text-slg-text-dark mb-4">Prefer to Chat First?</h3>
              <div class="space-y-4">
                <div>
                  <p class="text-xs text-slg-text-dark/60 uppercase tracking-wider font-semibold mb-1">Phone</p>
                  <a href="tel:0432558304" class="text-slg-text-dark font-bold hover:text-slg-pink transition-colors">0432 558 304</a>
                </div>
                <div>
                  <p class="text-xs text-slg-text-dark/60 uppercase tracking-wider font-semibold mb-1">Email</p>
                  <a href="mailto:soullabgym@gmail.com" class="text-slg-text-dark font-bold hover:text-slg-pink transition-colors">soullabgym@gmail.com</a>
                </div>
              </div>
            </div>
            <div class="bg-slg-bone border-l-4 border-slg-pink/30 p-8">
              <h3 class="text-lg font-display uppercase text-slg-text-dark mb-3">Pricing</h3>
              <div class="space-y-3">
                <div class="flex justify-between items-center border-b border-gray-200 pb-3">
                  <span class="text-slg-text-dark font-semibold">Single session (30 min)</span>
                  <span class="text-slg-pink font-black text-xl">$50</span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-slg-text-dark font-semibold">5+ sessions</span>
                  <span class="text-slg-pink font-black text-xl">$40 <span class="text-sm font-normal text-slg-text-dark">each</span></span>
                </div>
                <p class="text-xs text-slg-text-dark/60 pt-2">Buy a pack of 5 or more and save $10 per session.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="py-20 bg-slg-bone">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl font-display uppercase text-slg-text-dark text-center mb-4">What You Get</h2>
        <p class="text-slg-text-dark text-lg text-center max-w-2xl mx-auto mb-16">
          Every private session is built around your specific goals, experience level, and schedule.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {[
            {
              title: 'Completely Personalised',
              desc: 'Your session is designed for YOU — your level, your goals, your timeline. No group compromises.',
              icon: '🎯',
            },
            {
              title: 'Flexible Scheduling',
              desc: 'Book around your life. Early mornings, evenings, weekends. We make it work for your schedule.',
              icon: '⏰',
            },
            {
              title: 'Faster Progress',
              desc: 'One-on-one attention means faster technique improvement and real accountability.',
              icon: '03',
            },
            {
              title: 'Expert Coaching',
              desc: 'Train with Joseph or a senior Soul Lab coach. Real fight experience. Real teaching ability.',
              icon: '04',
            },
            {
              title: 'Head Start for Beginners',
              desc: 'Build a solid foundation before joining group classes. Feel confident from day one.',
              icon: '05',
            },
            {
              title: 'Injury-Safe Training',
              desc: 'Modified programming that keeps you moving safely if you\'re coming back from injury.',
              icon: '06',
            },
          ].map(item => (
            <div class="bg-slg-bone border-2 border-slg-pink/30 hover:border-slg-pink rounded-none p-8 transition-all hover:shadow-lg">
              <div class="font-display text-5xl text-slg-pink leading-none mb-4">{item.icon}</div>
              <h3 class="text-xl font-display uppercase text-slg-text-dark mb-3">{item.title}</h3>
              <p class="text-slg-text-dark leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHO IT'S FOR -->
    <section class="py-20 bg-slg-bone">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl font-display uppercase text-slg-text-dark text-center mb-4">Perfect For:</h2>
        <p class="text-slg-text-dark text-lg text-center max-w-2xl mx-auto mb-16">
          Whether you're starting from scratch or training for competition, we have a program for you.
        </p>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          {[
            {
              title: 'Fight Preparation',
              points: [
                'Camp-specific coaching for your next bout',
                'Opponent analysis and strategy',
                'Mental toughness preparation',
                'Strength & conditioning tailored to your style',
              ],
            },
            {
              title: 'Complete Beginners',
              points: [
                'Build solid fundamentals before group classes',
                'Learn safely with focused attention',
                'Gain confidence in a judgment-free space',
                'Progress at your own pace',
              ],
            },
            {
              title: 'Technique Refinement',
              points: [
                'Laser-focus on specific skills you want to sharpen',
                'Correct bad habits before they stick',
                'Advanced technique from experienced coaches',
                'Consistent feedback and adjustment',
              ],
            },
            {
              title: 'Injury Recovery',
              points: [
                'Modified training that keeps you moving safely',
                'Sport-specific rehab to return stronger',
                'Work around existing injuries or limitations',
                'Prevention coaching to avoid future issues',
              ],
            },
          ].map(category => (
            <div class="bg-slg-bone border-2 border-slg-pink/30 rounded-none p-10 hover:shadow-lg transition-shadow">
              <h3 class="text-2xl font-display uppercase text-slg-text-dark mb-6">{category.title}</h3>
              <ul class="space-y-4">
                {category.points.map(point => (
                  <li class="flex gap-3">
                    <span class="text-slg-pink font-bold flex-shrink-0 mt-0.5">✓</span>
                    <span class="text-slg-text-dark leading-relaxed">{point}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PRICING SECTION -->
    <section class="py-20 bg-slg-bone">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl font-display uppercase text-slg-text-dark mb-4">Pricing</h2>
        <p class="text-slg-text-dark text-lg mb-12">Simple, transparent pricing. No lock-ins.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-slg-bone border-2 border-gray-200 hover:border-slg-pink p-10 transition-all hover:shadow-lg">
            <h3 class="text-xl font-display uppercase text-slg-text-dark mb-4">Single Session</h3>
            <div class="text-5xl font-black text-slg-pink mb-2">$50</div>
            <p class="text-slg-text-dark/60 text-sm mb-4">30 minutes · Pay as you go</p>
            <p class="text-slg-text-dark">Perfect for a one-off session or trying it out before committing.</p>
          </div>
          <div class="bg-slg-bone border-2 border-slg-pink shadow-lg p-10 relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-slg-pink text-white text-xs font-bold uppercase tracking-widest px-4 py-1">Best Value</div>
            <h3 class="text-xl font-display uppercase text-slg-text-dark mb-4">Pack of 5+</h3>
            <div class="text-5xl font-black text-slg-pink mb-2">$40</div>
            <p class="text-slg-text-dark/60 text-sm mb-4">per session · Save $10 each</p>
            <p class="text-slg-text-dark">Buy 5 or more sessions and lock in the discounted rate. Best for consistent progress.</p>
          </div>
        </div>
        <p class="text-slg-text-dark/60 text-sm mt-8">All sessions are one-on-one with a Soul Lab coach. Want Joseph specifically? Contact us about availability.</p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-slg-bone">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-4xl font-display uppercase font-display uppercase text-center mb-16">Frequently Asked</h2>

        <div class="space-y-6">
          {[
            {
              q: 'Do I need to have trained before?',
              a: 'Nope. We design sessions for complete beginners. Private training is actually the best way to start — you get a solid foundation before joining group classes.',
            },
            {
              q: 'Can I book specific coaches?',
              a: 'Absolutely. Want Joseph? We can arrange it based on availability. Otherwise you\'ll train with one of our senior coaches — all experienced fighters and excellent teachers.',
            },
            {
              q: 'How long are sessions?',
              a: 'All private sessions are 30 minutes. Short, focused, and effective — no filler.',
            },
            {
              q: 'What if I need to reschedule?',
              a: '48 hours notice and we\'ll move your session. Life happens — we get it.',
            },
            {
              q: 'Can I combine private and group classes?',
              a: 'Yes! Many people do private sessions for focused work, then join group classes for community and extra volume. We can help you structure a plan that works.',
            },
            {
              q: 'Do I need to bring anything?',
              a: 'Just yourself and comfortable workout gear. We have gloves, wraps, and pads here. If you want to use your own gear, bring it.',
            },
          ].map((faq, i) => (
            <div class="bg-slg-bone border-2 border-slg-pink/30 hover:border-slg-pink rounded-none p-8 transition-all">
              <h3 class="text-lg font-bold font-display uppercase mb-4">{faq.q}</h3>
              <p class="text-slg-text-dark leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <Footer />
</Layout>
