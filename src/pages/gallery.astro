---

<Layout
  title="Photo Gallery — Soul Lab Gym"
  description="Photo gallery of Soul Lab Gym training, coaching, kids programs, and team. See our state-of-the-art facility and community in action."
>
  <Nav />

  <!-- HERO -->
  <section class="relative min-h-[300px] flex items-center justify-center pt-16 overflow-hidden bg-gradient-to-br from-green-50 via-white to-pink-50">
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-16">
      <h1 class="text-5xl sm:text-6xl font-black text-gray-900 leading-tight mb-4">
        Photo Gallery
      </h1>
      <p class="text-xl sm:text-2xl text-gray-700 font-medium max-w-2xl mx-auto">
        Real training, real results, real community at Soul Lab Gym
      </p>
    </div>
  </section>

  <!-- GALLERY GRID -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Filter Buttons -->
      <div class="flex flex-wrap justify-center gap-3 mb-14">
        {['All', 'Featured', 'Training', 'Kids', 'Achievement', 'Community', 'Gym', 'Brand', 'Info'].map(cat => (
          <button
            class="filter-btn px-6 py-2 rounded-full font-bold text-sm transition-all border-2"
            data-filter={cat}
            data-active={cat === 'All' ? 'true' : 'false'}
            style={{
              backgroundColor: cat === 'All' ? 'rgb(236, 72, 153)' : 'white',
              borderColor: 'rgb(236, 72, 153)',
              color: cat === 'All' ? 'white' : 'rgb(236, 72, 153)',
            }}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Photo Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {allPhotos.map((photo, idx) => (
          <div 
            class="gallery-item group relative overflow-hidden rounded-2xl aspect-square cursor-pointer border-2 border-gray-200 hover:border-pink-400 transition-all hover:shadow-xl"
            data-category={photo.category}
            onclick={`openLightbox(${idx})`}
          >
            <img 
              src={photo.src} 
              alt={photo.alt} 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300" 
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors"></div>
            <div class="absolute inset-0 flex items-end p-4 opacity-0 group-hover:opacity-100 transition-opacity">
              <h3 class="text-white font-bold text-lg">{photo.title}</h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LIGHTBOX MODAL -->
  <div id="lightbox" class="hidden fixed inset-0 z-50 bg-black/90 flex items-center justify-center p-4">
    <button 
      id="lightbox-close"
      class="absolute top-6 right-6 text-white text-4xl hover:text-pink-500 transition-colors"
    >
      ✕
    </button>
    
    <div class="relative w-full max-w-4xl">
      <img id="lightbox-image" src="" alt="" class="w-full h-auto rounded-xl" />
      <button 
        id="lightbox-prev"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-16 text-white text-4xl hover:text-pink-500 transition-colors"
      >
        ‹
      </button>
      <button 
        id="lightbox-next"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-16 text-white text-4xl hover:text-pink-500 transition-colors"
      >
        ›
      </button>
      <p id="lightbox-title" class="text-white text-center mt-4 text-lg font-bold"></p>
    </div>
  </div>

  <Footer />
</Layout>

<script>
  const allPhotos = {allPhotos};
  let currentIndex = 0;
  let filteredIndices = Array.from({length: allPhotos.length}, (_, i) => i);

  // Filter functionality
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.style.backgroundColor = 'white';
        b.style.color = 'rgb(236, 72, 153)';
      });
      btn.style.backgroundColor = 'rgb(236, 72, 153)';
      btn.style.color = 'white';

      const filter = btn.getAttribute('data-filter');
      
      if (filter === 'All') {
        filteredIndices = Array.from({length: allPhotos.length}, (_, i) => i);
        document.querySelectorAll('.gallery-item').forEach(item => {
          item.style.display = 'block';
        });
      } else {
        filteredIndices = allPhotos
          .map((p, i) => p.category === filter ? i : null)
          .filter(i => i !== null);
        
        document.querySelectorAll('.gallery-item').forEach((item, i) => {
          item.style.display = filteredIndices.includes(i) ? 'block' : 'none';
        });
      }
    });
  });

  // Lightbox functionality
  function openLightbox(idx) {
    currentIndex = filteredIndices.indexOf(idx);
    updateLightbox();
    document.getElementById('lightbox').classList.remove('hidden');
  }

  function updateLightbox() {
    const photoIdx = filteredIndices[currentIndex];
    const photo = allPhotos[photoIdx];
    document.getElementById('lightbox-image').src = photo.src;
    document.getElementById('lightbox-image').alt = photo.alt;
    document.getElementById('lightbox-title').textContent = photo.title;
  }

  document.getElementById('lightbox-close').addEventListener('click', () => {
    document.getElementById('lightbox').classList.add('hidden');
  });

  document.getElementById('lightbox-prev').addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + filteredIndices.length) % filteredIndices.length;
    updateLightbox();
  });

  document.getElementById('lightbox-next').addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % filteredIndices.length;
    updateLightbox();
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (document.getElementById('lightbox').classList.contains('hidden')) return;
    if (e.key === 'ArrowLeft') document.getElementById('lightbox-prev').click();
    if (e.key === 'ArrowRight') document.getElementById('lightbox-next').click();
    if (e.key === 'Escape') document.getElementById('lightbox-close').click();
  });
</script>
