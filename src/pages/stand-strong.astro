---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Stand Strong — Soul Lab Gym"
  description="Stand Strong by Soul Lab Gym. A free 2-day anti-bullying program for Townsville kids during Queensland school holidays."
>
  <Nav />

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/photos/kids-guard-pose-group.jpg" alt="Stand Strong kids training" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-black/55"></div>

    <div class="relative z-10 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
      <div class="inline-block bg-slg-pink text-white text-xs font-semibold uppercase tracking-widest px-4 py-2 mb-6">
        Free Programs • Soul Lab Gym
      </div>
      <h1 class="text-6xl sm:text-7xl lg:text-8xl font-display uppercase leading-tight text-white mb-6">
        Stand<br><span class="text-slg-pink">Strong</span>
      </h1>
      <p class="text-xl sm:text-2xl text-white/90 font-medium mb-10 max-w-xl mx-auto">
        A free 2-day program giving Townsville kids real confidence and real tools to handle bullying.
      </p>

      <!-- Coming Soon Badge -->
      <div class="inline-block border-2 border-slg-pink/60 bg-black/40 px-8 py-5 mb-10">
        <p class="text-slg-pink text-xs font-bold uppercase tracking-widest mb-1">Next Seminar</p>
        <p class="text-white text-2xl font-display uppercase font-bold">Queensland School Holidays</p>
        <p class="text-white/60 text-sm mt-1">2 days · All ages welcome · Completely free</p>
      </div>

      <div class="block">
        <a
          href="#notify"
          class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-10 py-4 transition-colors"
        >
          Get Notified When Spots Open
        </a>
      </div>
    </div>
  </section>

  <!-- WHAT IT IS -->
  <section class="py-20 bg-slg-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-block bg-slg-pink text-white text-xs font-semibold uppercase tracking-widest px-4 py-2 mb-6">
            The Program
          </div>
          <h2 class="text-4xl sm:text-5xl font-display uppercase text-slg-text-dark leading-tight mb-6">
            Two days that change how kids carry themselves.
          </h2>
          <p class="text-lg text-slg-text-dark leading-relaxed mb-6">
            Stand Strong isn't lectures and worksheets. It's real, physical, practical training — using martial arts principles and accredited anti-bullying frameworks to build genuine confidence in kids aged 6–14.
          </p>
          <p class="text-lg text-slg-text-dark leading-relaxed">
            Led by Joseph Gabiola — WMO State Champion and accredited anti-bullying educator — every session runs over two full days during the Queensland school holidays.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-6">
          <div class="bg-slg-bone border-2 border-slg-pink/30 p-8">
            <div class="text-slg-pink text-xs font-bold uppercase tracking-widest mb-3">Day 1</div>
            <h3 class="text-xl font-display uppercase text-slg-text-dark mb-4">Grounding & Presence</h3>
            <ul class="space-y-2 text-slg-text-dark">
              <li class="flex gap-3"><span class="text-slg-pink font-bold">✓</span> Posture, breathing & body awareness</li>
              <li class="flex gap-3"><span class="text-slg-pink font-bold">✓</span> Reading situations and setting boundaries</li>
              <li class="flex gap-3"><span class="text-slg-pink font-bold">✓</span> Building the mindset of calm confidence</li>
            </ul>
          </div>
          <div class="bg-slg-bone border-2 border-slg-pink/30 p-8">
            <div class="text-slg-pink text-xs font-bold uppercase tracking-widest mb-3">Day 2</div>
            <h3 class="text-xl font-display uppercase text-slg-text-dark mb-4">Tools You Can Actually Use</h3>
            <ul class="space-y-2 text-slg-text-dark">
              <li class="flex gap-3"><span class="text-slg-pink font-bold">✓</span> Verbal de-escalation & confident voice work</li>
              <li class="flex gap-3"><span class="text-slg-pink font-bold">✓</span> Movement for safety (age-appropriate)</li>
              <li class="flex gap-3"><span class="text-slg-pink font-bold">✓</span> Handling social media & group pressure</li>
            </ul>
            <p class="text-xs text-slg-pink font-semibold mt-4 pt-4 border-t border-slg-pink/20">Small graduation + parent debrief at end of day 2</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- JOSEPH -->
  <section class="py-20 bg-slg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-slg-pink text-white text-xs font-semibold uppercase tracking-widest px-4 py-2 mb-6">
            The Coach
          </div>
          <h2 class="text-4xl font-display uppercase text-white mb-4">Joseph Gabiola</h2>
          <p class="text-white/60 mb-6">Head Coach & Founder, Soul Lab Gym · WMO State Champion</p>
          <blockquote class="text-white/80 text-lg leading-relaxed border-l-4 border-slg-pink pl-6">
            "I don't believe in teaching kids to be aggressive. I believe in teaching them to be so grounded, calm, and aware that most problems never escalate — and if they do, they have genuine options. That's what martial arts gave me. That's what I want to give the next generation in Townsville."
          </blockquote>
        </div>
        <div class="overflow-hidden aspect-square">
          <img src="/photos/joseph-ring-portrait.jpg" alt="Joseph Gabiola, Soul Lab Gym" class="w-full h-full object-cover object-top" />
        </div>
      </div>
    </div>
  </section>

  <!-- NOTIFY -->
  <section id="notify" class="py-20 bg-slg-pink">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl sm:text-5xl font-display uppercase text-white mb-4">Be First to Know</h2>
      <p class="text-white/80 text-lg mb-10">
        Spots fill fast. Leave your details and we'll reach out as soon as the next Queensland school holidays program opens for registration.
      </p>
      <div class="bg-white p-8">
        <form class="space-y-4">
          <input type="text" placeholder="Parent name" class="w-full px-4 py-3 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-slg-pink" required />
          <input type="email" placeholder="Email address" class="w-full px-4 py-3 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-slg-pink" required />
          <input type="tel" placeholder="Phone number" class="w-full px-4 py-3 border border-gray-300 focus:outline-none focus:ring-2 focus:ring-slg-pink" />
          <button type="submit" class="w-full bg-slg-dark hover:bg-black text-white font-bold text-sm uppercase tracking-wide py-4 transition-colors">
            Notify Me When Spots Open
          </button>
        </form>
        <p class="mt-4 text-xs text-gray-400">No spam. We'll only contact you about Stand Strong dates.</p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
