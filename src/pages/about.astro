---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="About — Soul Lab Gym"
  description="Soul Lab Gym is Townsville's home for authentic Muay Thai training. Meet head coach Joseph Gabiola, WMO State Champion."
>
  <Nav />

  <div class="pt-16">
    <!-- PAGE HEADER -->
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-5xl sm:text-6xl font-black text-gray-900 mb-6">
          About <span class="text-pink-500">Soul Lab Gym</span>
        </h1>
        <p class="text-gray-700 text-lg leading-relaxed max-w-2xl mx-auto">
          Soul Lab Gym is Townsville's home for authentic Muay Thai training. We're serious about technique, serious about community, and serious about getting results — whether you're a kid stepping on the mat for the first time or a seasoned fighter preparing for your next bout.
        </p>
      </div>
    </section>

    <!-- HEAD COACH -->
    <section class="py-16 bg-gradient-to-b from-green-50 to-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-black text-gray-900 text-center mb-12">Meet the Coach</h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-4xl mx-auto">
          <!-- Hero Photo -->
          <div class="bg-white border-2 border-green-200 rounded-2xl overflow-hidden aspect-square group hover:shadow-lg transition-shadow">
            <img src="/photos/joseph-kids-hero.jpg" alt="Joseph Gabiola coaching" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
          </div>

          <!-- Bio -->
          <div>
            <div class="inline-block bg-pink-100 border border-pink-300 text-pink-700 text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-4">
              Head Coach
            </div>
            <h3 class="text-3xl font-black text-gray-900 mb-2">Joseph Gabiola</h3>
            <div class="text-pink-500 font-semibold mb-6">WMO State Champion</div>
            <p class="text-gray-700 text-lg leading-relaxed mb-6">
              Joseph is a WMO State Champion with decades of fighting experience and a proven track record developing athletes from beginner to competitive level. He founded Soul Lab Gym on one principle: authentic coaching, delivered with care.
            </p>
            <p class="text-gray-700 text-lg leading-relaxed mb-6">
              Beyond the ring, Joseph is passionate about building confidence in kids through martial arts — teaching that real strength comes from discipline, respect, and understanding your own power. His anti-bullying programs have helped hundreds of Townsville families, and his gym is home to fighters, kids, and community members from all walks of life.
            </p>
            <p class="text-gray-700 text-lg leading-relaxed">
              When Joseph coaches, he's not just teaching Muay Thai. He's building people who carry themselves with quiet confidence and treat others with respect.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- PHOTO GALLERY -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-black text-gray-900 text-center mb-10">The Gym</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <div class="bg-white border-2 border-gray-200 rounded-lg aspect-square overflow-hidden hover:border-pink-300 transition-colors group">
            <img src="/photos/gym-wide-shot.jpg" alt="Gym wide shot" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-lg aspect-square overflow-hidden hover:border-pink-300 transition-colors group">
            <img src="/photos/coach-pads.jpg" alt="Coach training" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-lg aspect-square overflow-hidden hover:border-pink-300 transition-colors group">
            <img src="/photos/adult-lined-up-class.jpg" alt="Adult class" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-lg aspect-square overflow-hidden hover:border-pink-300 transition-colors group">
            <img src="/photos/training-women-pad-work.jpg" alt="Pad work" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-lg aspect-square overflow-hidden hover:border-pink-300 transition-colors group">
            <img src="/photos/team-photo.jpg" alt="Team photo" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
          </div>
          <div class="bg-white border-2 border-gray-200 rounded-lg aspect-square overflow-hidden hover:border-pink-300 transition-colors group">
            <img src="/photos/kids-guard-pose-group.jpg" alt="Kids training" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
          </div>
        </div>
      </div>
    </section>

    <!-- VALUES -->
    <section class="py-16 bg-gradient-to-b from-green-50 to-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-black text-gray-900 text-center mb-12">What We're About</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { title: 'Authentic Technique', desc: 'Real Muay Thai from coaches who compete and win.' },
            { title: 'Family Friendly', desc: 'A safe, welcoming space for all ages and experience levels.' },
            { title: 'Real Results', desc: 'Structured progression that builds champions inside and outside the gym.' },
            { title: 'True Community', desc: 'Teammates who show up, support each other, and push each other forward.' },
          ].map(item => (
            <div class="bg-white border-2 border-green-200 hover:border-pink-300 rounded-xl p-6 text-center transition-colors">
              <h3 class="font-bold text-gray-900 mb-2">{item.title}</h3>
              <p class="text-gray-700 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-white">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-black text-gray-900 mb-4">Come be part of it.</h2>
        <p class="text-gray-700 mb-8">Your first week is on us. No commitment, no pressure.</p>
        <a
          href="https://slg.gymdesk.com/signup"
          class="inline-block bg-pink-700 hover:bg-pink-800 text-white font-bold text-base px-8 py-4 rounded-full transition-all shadow-lg"
        >
          Claim Your 7-Day Pass
        </a>
      </div>
    </section>
  </div>

  <Footer />
</Layout>
