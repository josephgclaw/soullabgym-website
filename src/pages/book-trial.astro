---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Book Your Free Trial — Soul Lab Gym"
  description="Start your 7-day free trial at Soul Lab Gym. Unlimited classes, a free pad session, and loaner gear included. Pick a class from the timetable and book your spot."
>
  <Nav />

  <div class="pt-16">

    <!-- PAGE HEADER -->
    <section class="py-20 bg-slg-bone">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-block text-xs font-bold uppercase px-3 py-1 mb-6 bg-slg-pink text-white tracking-wider">Free Trial</div>
        <h1 class="text-5xl sm:text-6xl font-display uppercase text-slg-text-dark mb-6">
          Book Your <span class="text-slg-pink">Trial Class</span>
        </h1>
        <p class="text-slg-text-dark text-lg leading-relaxed max-w-2xl mx-auto">
          Your first class is on us. Browse the live timetable below, pick a session that suits you, and book directly into that slot — no experience needed, loaner gear provided.
        </p>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="py-16 bg-slg-dark">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-display uppercase text-white text-center mb-12">What's Included</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="border border-slg-pink/30 p-8 text-center">
            <div class="text-slg-pink text-4xl mb-4">1×</div>
            <h3 class="text-white font-bold text-lg uppercase tracking-wide mb-2">Free Trial Class</h3>
            <p class="text-white/70 text-sm leading-relaxed">Join any class on the schedule. Train alongside the team, coached from the ground up — no experience needed.</p>
          </div>
          <div class="border border-slg-pink/30 p-8 text-center">
            <div class="text-slg-pink mb-4">
              <svg class="w-10 h-10 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <h3 class="text-white font-bold text-lg uppercase tracking-wide mb-2">Loaner Gear Included</h3>
            <p class="text-white/70 text-sm leading-relaxed">Don't own gloves or wraps? No problem. We kit you out so you can just show up and train.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="py-16 bg-slg-bone">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-display uppercase text-slg-text-dark text-center mb-12">How It Works</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          <div>
            <div class="w-12 h-12 bg-slg-pink text-white font-display text-2xl flex items-center justify-center mx-auto mb-4">1</div>
            <h3 class="font-bold text-slg-text-dark uppercase tracking-wide mb-2">Pick a Class</h3>
            <p class="text-slg-text-dark/80 text-sm leading-relaxed">Browse the live timetable below and find a session that works for your schedule.</p>
          </div>
          <div>
            <div class="w-12 h-12 bg-slg-pink text-white font-display text-2xl flex items-center justify-center mx-auto mb-4">2</div>
            <h3 class="font-bold text-slg-text-dark uppercase tracking-wide mb-2">Book Your Spot</h3>
            <p class="text-slg-text-dark/80 text-sm leading-relaxed">Click the class to book directly into that slot. Takes 60 seconds — no credit card required.</p>
          </div>
          <div>
            <div class="w-12 h-12 bg-slg-pink text-white font-display text-2xl flex items-center justify-center mx-auto mb-4">3</div>
            <h3 class="font-bold text-slg-text-dark uppercase tracking-wide mb-2">Show Up & Train</h3>
            <p class="text-slg-text-dark/80 text-sm leading-relaxed">Come in, grab loaner gear if you need it, and let a coach take you through your first session.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TIMETABLE -->
    <section class="py-16 bg-slg-bone" id="timetable">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-4xl font-display uppercase text-slg-text-dark mb-3">
            Pick Your <span class="text-slg-pink">Class</span>
          </h2>
          <p class="text-slg-text-dark/80 text-base max-w-xl mx-auto">
            All sessions are open to beginners unless marked otherwise. Click a class in the schedule to book your trial spot.
          </p>
        </div>

        <!-- CLASS LEVELS -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <div class="bg-slg-bone border-2 border-slg-pink/30 p-6">
            <span class="bg-slg-bone border border-slg-pink/30 text-slg-text-dark text-xs font-bold uppercase tracking-wider px-3 py-1 inline-block mb-3">Level 1</span>
            <h3 class="text-lg font-bold text-slg-text-dark mb-2">All Levels Welcome</h3>
            <p class="text-slg-text-dark/80 text-sm leading-relaxed">Whether it's your first session or you've trained for years — coaches scale every class to meet you where you're at.</p>
          </div>
          <div class="bg-slg-bone border-2 border-slg-pink/30 p-6">
            <span class="bg-slg-bone border border-slg-pink text-slg-pink text-xs font-bold uppercase tracking-wider px-3 py-1 inline-block mb-3">Level 2</span>
            <h3 class="text-lg font-bold text-slg-text-dark mb-2">Intermediate</h3>
            <p class="text-slg-text-dark/80 text-sm leading-relaxed">Technique-driven sessions with pad rounds, partner drills, and conditioning. For students who know the basics.</p>
          </div>
          <div class="bg-slg-bone border-2 border-slg-pink/30 p-6">
            <span class="bg-slg-bone border border-slg-pink text-slg-pink text-xs font-bold uppercase tracking-wider px-3 py-1 inline-block mb-3">Level 3 — Invite Only</span>
            <h3 class="text-lg font-bold text-slg-text-dark mb-2">Fighters / Advanced</h3>
            <p class="text-slg-text-dark/80 text-sm leading-relaxed">Invitation-only training blocks for fighters. Sparring, clinch, and fight camp preparation.</p>
          </div>
        </div>

        <!-- GYMDESK WIDGET -->
        <div class="bg-slg-bone border-2 border-slg-pink/30 p-8">
          <div id="gymdesk-widget-trial" class="gymdesk-schedule" attr-gym="DLVb1" attr-visible_schedule="all" attr-default_schedule="all"></div>
        </div>

        <script>
          document.addEventListener('DOMContentLoaded', function() {
            if (window.GymDeskWidgets) {
              window.GymDeskWidgets.initAll();
            }
          });
          if (window.GymDeskWidgets) {
            window.GymDeskWidgets.initAll();
          }
        </script>
      </div>
    </section>

    <!-- CLAIM TRIAL CTA -->
    <section class="py-20 bg-slg-dark">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl sm:text-5xl font-display uppercase text-white mb-4">
          Ready to <span class="text-slg-pink">Start?</span>
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-xl mx-auto leading-relaxed">
          One free class, no strings attached. Pick a session from the timetable, show up, and train. Loaner gear provided.
        </p>
        <a
          href="https://soullabgymoffer.com/offer"
          class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-widest px-10 py-5 transition-colors"
        >
          Claim Free Trial + Gear Pack
        </a>
        <p class="text-white/40 text-xs mt-6 uppercase tracking-wider">No credit card required · Cancel anytime</p>
      </div>
    </section>

  </div>

  <Footer />
</Layout>
