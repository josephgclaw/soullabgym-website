---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Soul Lab Gym — Townsville's Muay Thai Home"
  description="Train with WMO state champion Joseph Gabiola. Muay Thai for families, fighters & future champions in Townsville."
>
  <Nav />

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/photos/joseph-kids-hero.jpg" alt="Joseph training kids" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-black/45"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
      <div class="space-y-4 mb-8">
        <!-- Main headline -->
        <h1 class="font-display text-4xl sm:text-5xl lg:text-7xl xl:text-8xl text-white uppercase leading-tight">
          Townsville's
        </h1>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-7xl xl:text-8xl text-white uppercase leading-tight">
          Muay Thai Home
        </h1>

        <!-- Sub-headlines with solid dark fill for readability -->
        <div class="pt-6 space-y-3 flex flex-col items-center">
          <h2 class="font-display text-4xl sm:text-5xl text-white bg-black/50 border border-white/40 px-6 py-3 inline-block uppercase">
            For Families
          </h2>
          <h2 class="font-display text-4xl sm:text-5xl text-white bg-black/50 border border-white/40 px-6 py-3 inline-block uppercase">
            Fighters
          </h2>
          <h2 class="font-display text-4xl sm:text-5xl text-white bg-black/50 border border-white/40 px-6 py-3 inline-block uppercase">
            & Future Champions
          </h2>
        </div>
      </div>

      <!-- CTA in hero -->
      <div class="pt-12 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded transition-colors shadow-lg"
        >
          Claim Free 7-Day Trial
        </a>
        <a
          href="/about"
          class="inline-block border-2 border-white hover:bg-white/10 text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded transition-colors"
        >
          Our Story
        </a>
      </div>
    </div>
  </section>

  <!-- CREDIBILITY BAR (NEW) -->
  <section style="background-color: #0E0E0E;" class="py-5">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-wrap justify-center items-center gap-6 md:gap-10 text-white text-xs font-semibold uppercase tracking-widest">
        <span>WMO State Champion</span>
        <span class="text-pink-500 text-lg">—</span>
        <span>55+ Reviews · 5.0★</span>
        <span class="text-pink-500 text-lg">—</span>
        <span>Townsville's Premier Gym</span>
        <span class="text-pink-500 text-lg">—</span>
        <span>Kids · Adults · Fighters</span>
      </div>
    </div>
  </section>

  <!-- WHO WE ARE -->
  <section class="py-20 bg-slg-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display text-5xl sm:text-6xl uppercase text-slg-text-dark leading-tight mb-6">
            Who We Are
          </h2>
          <p class="text-slg-text-dark text-lg leading-relaxed mb-6">
            Soul Lab Gym is Townsville's premier Muay Thai home, built on real expertise, authentic coaching, and a commitment to every person who walks through our doors.
          </p>
          <p class="text-slg-text-dark text-lg leading-relaxed mb-6">
            Founded and led by <strong>Joseph Gabiola</strong>, a WMO state champion with decades of fighting experience, Soul Lab combines technical mastery with genuine care for each student's growth.
          </p>
          <p class="text-slg-text-dark text-lg leading-relaxed mb-8">
            We're not just a gym. We're a community where discipline meets joy, where fighting skills become life skills, and where every person discovers their own strength.
          </p>
          <a
            href="/about"
            class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded transition-colors shadow-lg"
          >
            Learn Our Full Story
          </a>
        </div>

        <div style="background-color: #0E0E0E;" class="p-10 border-l-4 border-pink-500 rounded-lg">
          <h3 class="text-2xl font-display uppercase text-white mb-6">Core Values</h3>
          <ul class="space-y-4">
            {[
              { title: 'Expert Coaching', desc: 'Real fighters teaching authentic Muay Thai with depth and strategy' },
              { title: 'Family First', desc: 'A safe, welcoming space for all ages and experience levels' },
              { title: 'Real Results', desc: 'Structured progression that builds champions inside and outside the gym' },
            ].map(value => (
              <li class="pb-4 border-b border-white/10 last:border-0">
                <h4 class="font-bold text-pink-500 mb-1">{value.title}</h4>
                <p class="text-white/70 text-sm">{value.desc}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE STAND FOR (PILLARS) - REDESIGNED -->
  <section class="!!bg-slg-dark py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-5xl sm:text-6xl uppercase text-white text-center mb-4">What We Stand For</h2>
      <p class="text-white/80 text-lg text-center max-w-2xl mx-auto mb-16">
        Three pillars guide everything we do at Soul Lab Gym.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/10">
        {[
          {
            num: '01',
            title: 'Fight-Ready Coaching',
            desc: 'Real competitors in your corner every session. Joseph and our senior coaches have fought and won. You\'re learning from people who live this.',
          },
          {
            num: '02',
            title: 'Confidence Building',
            desc: 'Kids leave bolder. Adults walk taller. Standing strong in the gym means standing strong everywhere. That\'s the real training.',
          },
          {
            num: '03',
            title: 'Community & Accountability',
            desc: 'You\'re not alone. We celebrate your wins, support your growth, and hold you accountable to becoming your best self.',
          },
        ].map(pillar => (
          <div class="!!bg-slg-dark p-10 hover:bg-white/5 transition-colors group">
            <div class="font-display text-8xl text-pink-500 leading-none mb-6">{pillar.num}</div>
            <h3 class="text-white font-bold text-xl mb-3">{pillar.title}</h3>
            <p class="text-white/80 leading-relaxed text-sm">{pillar.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7-DAY TRIAL SECTION -->
  <section class="!!bg-slg-dark py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display text-5xl sm:text-6xl uppercase text-white leading-tight mb-6">
            Start Your 7-Day Free Trial
          </h2>
          <p class="text-white text-lg leading-relaxed mb-8">
            No commitment. No credit card. Just real Muay Thai, real coaching, and real results.
          </p>

          <div class="space-y-4 mb-10">
            {[
              'Complete beginners welcome',
              'All equipment provided (gloves, wraps)',
              'Flexible class schedule — find what fits you',
              'Expert coaches who actually care about your progress',
            ].map(benefit => (
              <div class="flex gap-3">
                <span class="text-pink-500 font-bold">→</span>
                <span class="text-white/75">{benefit}</span>
              </div>
            ))}
          </div>

          <a
            href="/contact"
            class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded transition-colors shadow-lg"
          >
            Claim Your 7-Day Pass
          </a>
        </div>

        <div class="bg-white/5 border border-white/10 p-8 rounded-lg">
          <h3 class="text-xl font-bold text-white mb-6">What Happens Next</h3>
          <div class="space-y-6">
            {[
              { step: '1', title: 'You Visit', desc: 'Show up in comfortable gear. We\'ll take care of the rest.' },
              { step: '2', title: 'You Train', desc: 'Join a class with Joseph or a senior coach. Real coaching, real community.' },
              { step: '3', title: 'You Feel It', desc: 'After 7 days you\'ll feel stronger, more confident, and part of something real.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="font-display text-4xl text-pink-500">{item.step}</div>
                <div>
                  <p class="font-bold text-white mb-1">{item.title}</p>
                  <p class="text-white/75 text-sm">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS - PULL QUOTES -->
  <section style="background-color: #0E0E0E;" class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div style="background-color: #EC4899; color: #ffffff;" class="inline-block text-xs font-bold uppercase px-3 py-1 rounded-full mb-6">Real Members</div>
      <h2 style="color: #ffffff;" class="font-display text-5xl sm:text-6xl uppercase mb-16">What They're Saying</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <div style="background-color: #0E0E0E; padding: 2rem;">
          <div style="color: #EC4899; font-size: 3.5rem; line-height: 1; margin-bottom: 1.5rem; font-family: 'Bebas Neue', sans-serif;">"</div>
          <p style="color: #ffffff; font-size: 1.25rem; font-weight: 500; font-style: italic; margin-bottom: 1.5rem; line-height: 1.625;">
            These guys are amazing!!! Such a family welcoming vibe, from the moment we first walked in. My kids were made to feel so comfortable & treated so kindly even though they'd never stepped foot into a gym before. You can tell this place is built from the heart - good vibes, respect & love!!
          </p>
          <p style="color: #ffffff; font-weight: bold;">Tee</p>
        </div>

        <div style="background-color: #0E0E0E; padding: 2rem;">
          <div style="color: #EC4899; font-size: 3.5rem; line-height: 1; margin-bottom: 1.5rem; font-family: 'Bebas Neue', sans-serif;">"</div>
          <p style="color: #ffffff; font-size: 1.25rem; font-weight: 500; font-style: italic; margin-bottom: 1.5rem; line-height: 1.625;">
            We have been members at soullab gym for a few weeks now. And I've noticed a huge change in my kids. I can't thank Joseph and the team at soul lab enough for everything they do
          </p>
          <p style="color: #ffffff; font-weight: bold;">Mel J.</p>
        </div>

        <div style="background-color: #0E0E0E; padding: 2rem;">
          <div style="color: #EC4899; font-size: 3.5rem; line-height: 1; margin-bottom: 1.5rem; font-family: 'Bebas Neue', sans-serif;">"</div>
          <p style="color: #ffffff; font-size: 1.25rem; font-weight: 500; font-style: italic; margin-bottom: 1.5rem; line-height: 1.625;">
            Hands down the best experience for legitimate, authentic, intense Muay Thai training that you will struggle to find anywhere else in Townsville. Great facility, great training, Joe is a trainer that will push you to become the best version
          </p>
          <p style="color: #ffffff; font-weight: bold;">Sam B.</p>
        </div>
      </div>

      <div class="text-center">
        <a
          href="/testimonials"
          style="border: 2px solid #EC4899; color: #EC4899; padding: 1rem 2rem; display: inline-block; font-weight: bold; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; border-radius: 0.25rem; transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1);"
          onmouseover="this.style.backgroundColor='#EC4899'; this.style.color='#ffffff';"
          onmouseout="this.style.backgroundColor='transparent'; this.style.color='#EC4899';"
        >
          Read All 55+ Reviews
        </a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section style="background-color: #EC4899;" class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 style="color: #ffffff;" class="font-display text-4xl sm:text-5xl lg:text-7xl xl:text-8xl uppercase leading-tight mb-6">
        Start Your 7 Days
      </h2>
      <p style="color: rgba(255, 255, 255, 0.8);" class="text-lg mb-12 max-w-2xl mx-auto">
        No commitment. No credit card. Just real Muay Thai, real coaching, real results.
      </p>
      <a
        href="/contact"
        style="background-color: #0E0E0E; color: #ffffff; padding: 1.25rem 2.5rem; display: inline-block; font-weight: bold; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; border-radius: 0.25rem; transition: all 0.15s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);"
        onmouseover="this.style.backgroundColor='#1A1A1A';"
        onmouseout="this.style.backgroundColor='#0E0E0E';"
      >
        Claim Your Free Trial
      </a>
    </div>
  </section>

  <Footer />
</Layout>
