---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Soul Lab Gym — Townsville's Muay Thai Home"
  description="Train with WMO state champion Joseph Gabiola. Muay Thai for families, fighters & future champions in Townsville."
>
  <Nav />

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/photos/joseph-kids-hero.jpg" alt="Joseph training kids" class="w-full h-full object-cover" />
    </div>
    <div class="absolute inset-0 bg-black/45"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-20">
      <div class="space-y-4 mb-8">
        <!-- Main headline -->
        <h1 class="font-display text-7xl sm:text-8xl lg:text-9xl text-white uppercase leading-tight">
          Townsville's
        </h1>
        <h1 class="font-display text-7xl sm:text-8xl lg:text-9xl text-white uppercase leading-tight">
          Muay Thai Home
        </h1>

        <!-- Sub-headlines with white borders instead of pink fill -->
        <div class="pt-6 space-y-3 flex flex-col items-center">
          <h2 class="font-display text-4xl sm:text-5xl text-white border-2 border-white px-6 py-3 inline-block uppercase">
            For Families
          </h2>
          <h2 class="font-display text-4xl sm:text-5xl text-white border-2 border-white px-6 py-3 inline-block uppercase">
            Fighters
          </h2>
          <h2 class="font-display text-4xl sm:text-5xl text-white border-2 border-white px-6 py-3 inline-block uppercase">
            & Future Champions
          </h2>
        </div>
      </div>

      <!-- CTA in hero -->
      <div class="pt-12 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded transition-colors shadow-lg"
        >
          Claim Free 7-Day Trial
        </a>
        <a
          href="/about"
          class="inline-block border-2 border-white hover:bg-white/10 text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded transition-colors"
        >
          Our Story
        </a>
      </div>
    </div>
  </section>

  <!-- CREDIBILITY BAR (NEW) -->
  <section class="bg-slg-dark py-5">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-wrap justify-center items-center gap-6 md:gap-10 text-slg-text-light text-xs font-semibold uppercase tracking-widest">
        <span>WMO State Champion</span>
        <span class="text-slg-pink text-lg">—</span>
        <span>55+ Reviews · 5.0★</span>
        <span class="text-slg-pink text-lg">—</span>
        <span>Townsville's Premier Gym</span>
        <span class="text-slg-pink text-lg">—</span>
        <span>Kids · Adults · Fighters</span>
      </div>
    </div>
  </section>

  <!-- WHO WE ARE -->
  <section class="py-20 bg-slg-bone">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display text-5xl sm:text-6xl uppercase text-slg-text-dark leading-tight mb-6">
            Who We Are
          </h2>
          <p class="text-slg-text-dark text-lg leading-relaxed mb-6">
            Soul Lab Gym is Townsville's premier Muay Thai home, built on real expertise, authentic coaching, and a commitment to every person who walks through our doors.
          </p>
          <p class="text-slg-text-dark text-lg leading-relaxed mb-6">
            Founded and led by <strong>Joseph Gabiola</strong>, a WMO state champion with decades of fighting experience, Soul Lab combines technical mastery with genuine care for each student's growth.
          </p>
          <p class="text-slg-text-dark text-lg leading-relaxed mb-8">
            We're not just a gym. We're a community where discipline meets joy, where fighting skills become life skills, and where every person discovers their own strength.
          </p>
          <a
            href="/about"
            class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded transition-colors shadow-lg"
          >
            Learn Our Full Story
          </a>
        </div>

        <div class="bg-slg-dark p-10 border-l-4 border-slg-pink rounded-lg">
          <h3 class="text-2xl font-display uppercase text-white mb-6">Core Values</h3>
          <ul class="space-y-4">
            {[
              { title: 'Expert Coaching', desc: 'Real fighters teaching authentic Muay Thai with depth and strategy' },
              { title: 'Family First', desc: 'A safe, welcoming space for all ages and experience levels' },
              { title: 'Real Results', desc: 'Structured progression that builds champions inside and outside the gym' },
            ].map(value => (
              <li class="pb-4 border-b border-white/10 last:border-0">
                <h4 class="font-bold text-slg-pink mb-1">{value.title}</h4>
                <p class="text-slg-text-light/70 text-sm">{value.desc}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE STAND FOR (PILLARS) - REDESIGNED -->
  <section class="bg-slg-dark py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-5xl sm:text-6xl uppercase text-white text-center mb-4">What We Stand For</h2>
      <p class="text-slg-text-light/60 text-lg text-center max-w-2xl mx-auto mb-16">
        Three pillars guide everything we do at Soul Lab Gym.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/10">
        {[
          {
            num: '01',
            title: 'Fight-Ready Coaching',
            desc: 'Real competitors in your corner every session. Joseph and our senior coaches have fought and won. You\'re learning from people who live this.',
          },
          {
            num: '02',
            title: 'Confidence Building',
            desc: 'Kids leave bolder. Adults walk taller. Standing strong in the gym means standing strong everywhere. That\'s the real training.',
          },
          {
            num: '03',
            title: 'Community & Accountability',
            desc: 'You\'re not alone. We celebrate your wins, support your growth, and hold you accountable to becoming your best self.',
          },
        ].map(pillar => (
          <div class="bg-slg-dark p-10 hover:bg-white/5 transition-colors group">
            <div class="font-display text-8xl text-slg-pink leading-none mb-6">{pillar.num}</div>
            <h3 class="text-white font-bold text-xl mb-3">{pillar.title}</h3>
            <p class="text-slg-text-light/70 leading-relaxed text-sm">{pillar.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7-DAY TRIAL SECTION -->
  <section class="bg-slg-dark py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="font-display text-5xl sm:text-6xl uppercase text-white leading-tight mb-6">
            Start Your 7-Day Free Trial
          </h2>
          <p class="text-slg-text-light text-lg leading-relaxed mb-8">
            No commitment. No credit card. Just real Muay Thai, real coaching, and real results.
          </p>

          <div class="space-y-4 mb-10">
            {[
              'Complete beginners welcome',
              'All equipment provided (gloves, wraps)',
              'Flexible class schedule — find what fits you',
              'Expert coaches who actually care about your progress',
            ].map(benefit => (
              <div class="flex gap-3">
                <span class="text-slg-pink font-bold">→</span>
                <span class="text-slg-text-light">{benefit}</span>
              </div>
            ))}
          </div>

          <a
            href="/contact"
            class="inline-block bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded transition-colors shadow-lg"
          >
            Claim Your 7-Day Pass
          </a>
        </div>

        <div class="bg-white/5 border border-white/10 p-8 rounded-lg">
          <h3 class="text-xl font-bold text-white mb-6">What Happens Next</h3>
          <div class="space-y-6">
            {[
              { step: '1', title: 'You Visit', desc: 'Show up in comfortable gear. We\'ll take care of the rest.' },
              { step: '2', title: 'You Train', desc: 'Join a class with Joseph or a senior coach. Real coaching, real community.' },
              { step: '3', title: 'You Feel It', desc: 'After 7 days you\'ll feel stronger, more confident, and part of something real.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="font-display text-4xl text-slg-pink">{item.step}</div>
                <div>
                  <p class="font-bold text-white mb-1">{item.title}</p>
                  <p class="text-slg-text-light/70 text-sm">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS PREVIEW -->
  <section class="bg-slg-bone py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-5xl sm:text-6xl uppercase text-slg-text-dark text-center mb-4">Real Members. Real Results.</h2>
      <p class="text-slg-text-dark text-lg text-center max-w-2xl mx-auto mb-16">
        55+ reviews. 5.0 stars. Real people, real transformations.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
        {[
          { name: 'Shannon Mein', category: 'Experienced Trainer', quote: 'Authentic Muay Thai training, the best facility in Townsville with genuine passion for teaching.' },
          { name: 'Robert & Eva\'s World', category: 'Long-time Members', quote: 'Our kids trained with Joseph for years. Professional coach, amazing staff, feels like home.' },
          { name: 'Tee', category: 'Parent', quote: 'Family welcoming vibe from day one. My kids felt comfortable and treated so kindly.' },
        ].map(testimonial => (
          <div class="bg-white border-2 border-slg-pink/30 rounded-lg p-6">
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map(() => (
                <span class="text-slg-pink">★</span>
              ))}
            </div>
            <p class="text-slg-text-dark italic font-medium mb-4">"{testimonial.quote}"</p>
            <p class="font-bold text-slg-text-dark">{testimonial.name}</p>
            <p class="text-sm text-slg-pink font-semibold">{testimonial.category}</p>
          </div>
        ))}
      </div>

      <div class="text-center">
        <a
          href="/testimonials"
          class="inline-block border-2 border-slg-pink hover:bg-slg-pink text-slg-pink hover:text-white font-bold text-sm uppercase tracking-wide px-8 py-4 rounded transition-colors"
        >
          Read All Reviews
        </a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-slg-pink py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-5xl sm:text-6xl uppercase text-white leading-tight mb-6">
        Ready to Find Your Strength?
      </h2>
      <p class="text-white text-lg mb-8 max-w-2xl mx-auto">
        Start your 7-day free trial today. No commitment. No credit card. Just real training.
      </p>
      <a
        href="/contact"
        class="inline-block bg-white hover:bg-slg-bone text-slg-pink font-bold text-sm uppercase tracking-wide px-10 py-5 rounded transition-colors shadow-lg"
      >
        Claim Your Free Trial Now
      </a>
    </div>
  </section>

  <Footer />
</Layout>
