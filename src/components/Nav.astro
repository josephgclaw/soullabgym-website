---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/testimonials', label: 'Testimonials' },
  { href: '/contact', label: 'Contact' },
];

const programLinks = [
  { href: '/timetable', label: 'Classes' },
  { href: '/private-training', label: 'Private Training' },
  { href: '/stand-strong', label: 'Stand Strong' },
  { href: '/recovery', label: 'Recovery' },
];

const currentPath = Astro.url.pathname;
---

<>
  <!-- Announcement Bar -->
  <div class="bg-slg-pink py-2 text-center text-xs text-white font-semibold uppercase tracking-widest">
    🥊 7-Day Free Trial — No commitment. <a href="/contact" class="underline underline-offset-2 hover:text-white/80">Claim yours →</a>
  </div>

  <nav class="relative z-50 bg-slg-bone/95 backdrop-blur-md border-b border-slg-pink/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-baseline gap-1.5 flex-shrink-0">
          <span class="font-display text-3xl text-slg-pink tracking-tight">SOUL LAB</span>
          <span class="font-body text-[10px] font-bold text-slg-text-dark/40 tracking-[0.35em] uppercase">Gym</span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-8">
          {navLinks.map(link => (
            <a
              href={link.href}
              class={`text-sm font-medium transition-colors ${
                currentPath === link.href 
                  ? 'text-slg-pink font-bold' 
                  : 'text-slg-text-dark hover:text-slg-pink'
              }`}
            >
              {link.label}
            </a>
          ))}

          <!-- Programs Dropdown -->
          <div class="relative group">
            <button class="text-sm font-medium text-slg-text-dark hover:text-slg-pink transition-colors flex items-center gap-1.5">
              Programs
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
            </button>
            <div class="absolute left-0 mt-2 w-48 bg-white border border-slg-pink/20 rounded shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
              {programLinks.map(link => (
                <a
                  href={link.href}
                  class="block px-4 py-3 text-sm text-slg-text-dark hover:bg-slg-bone hover:text-slg-pink transition-colors first:rounded-t last:rounded-b"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>

          <!-- Auth & CTA -->
          <div class="flex items-center gap-4 border-l border-slg-pink/20 pl-8">
            <a
              href="https://slg.gymdesk.com/login"
              class="text-sm font-medium text-slg-text-dark hover:text-slg-pink transition-colors"
            >
              Login
            </a>
            <a
              href="https://slg.gymdesk.com/signup"
              class="bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-6 py-2 rounded-full transition-colors"
            >
              Start Free Trial
            </a>
          </div>
        </div>

        <!-- Mobile Hamburger -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 text-slg-text-dark hover:text-slg-pink focus:outline-none"
          aria-label="Toggle menu"
        >
          <svg id="hamburger-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-slg-bone border-t border-slg-pink/20">
      <div class="px-4 py-4 flex flex-col gap-4">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors ${
              currentPath === link.href 
                ? 'text-slg-pink font-bold' 
                : 'text-slg-text-dark hover:text-slg-pink'
            }`}
          >
            {link.label}
          </a>
        ))}

        <div class="border-t border-slg-pink/20 pt-4">
          <p class="text-xs font-semibold text-slg-text-dark/60 uppercase tracking-widest mb-3">Programs</p>
          {programLinks.map(link => (
            <a
              href={link.href}
              class="block text-sm text-slg-text-dark hover:text-slg-pink transition-colors py-2"
            >
              {link.label}
            </a>
          ))}
        </div>

        <div class="border-t border-slg-pink/20 pt-4 flex flex-col gap-3">
          <a
            href="https://slg.gymdesk.com/login"
            class="text-sm font-medium text-slg-text-dark hover:text-slg-pink transition-colors text-center py-2"
          >
            Login
          </a>
          <a
            href="https://slg.gymdesk.com/signup"
            class="bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-6 py-3 rounded-full transition-colors text-center"
          >
            Start Free Trial
          </a>
        </div>
      </div>
    </div>
  </nav>
</>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    hamburger?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  });
</script>
