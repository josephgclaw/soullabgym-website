---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/timetable', label: 'Timetable' },
  { href: '/stand-strong', label: 'Stand Strong' },
  { href: '/recovery', label: 'Recovery' },
  { href: '/testimonials', label: 'Testimonials' },
  { href: '/private-training', label: 'Private Training' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="bg-white border-t border-gray-200 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <!-- Brand & Logo -->
      <div>
        <img src="/logo.png" alt="Soul Lab Gym" class="h-24 mb-4" />
        <p class="text-gray-600 text-sm leading-relaxed">
          Townsville's Muay Thai Home for Families, Fighters & Future Champions
        </p>
      </div>

      <!-- Navigation Links -->
      <div>
        <h3 class="text-gray-900 font-bold mb-4 text-sm uppercase tracking-wider">Navigation</h3>
        <ul class="flex flex-col gap-2">
          {navLinks.slice(0, 4).map(link => (
            <li>
              <a href={link.href} class="text-gray-600 hover:text-amber-600 text-sm transition-colors font-medium">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- More Links -->
      <div>
        <h3 class="text-gray-900 font-bold mb-4 text-sm uppercase tracking-wider">Programs</h3>
        <ul class="flex flex-col gap-2">
          {navLinks.slice(4, 8).map(link => (
            <li>
              <a href={link.href} class="text-gray-600 hover:text-amber-600 text-sm transition-colors font-medium">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact & Social -->
      <div>
        <h3 class="text-gray-900 font-bold mb-4 text-sm uppercase tracking-wider">Contact</h3>
        <ul class="flex flex-col gap-3 text-sm text-gray-600 mb-6">
          <li>
            <a href="tel:0432558304" class="hover:text-amber-600 transition-colors font-medium">📞 0432 558 304</a>
          </li>
          <li>
            <a href="mailto:info@soullabgym.com" class="hover:text-amber-600 transition-colors font-medium">📧 info@soullabgym.com</a>
          </li>
          <li class="text-gray-700">📍 2/70 Ingham Road, West End, Townsville QLD</li>
        </ul>
        
        <!-- Social Links -->
        <h3 class="text-gray-900 font-bold mb-4 text-sm uppercase tracking-wider">Follow Us</h3>
        <div class="flex gap-4">
          <a href="https://www.instagram.com/soul.lab.gym/" target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-pink-500 transition-colors text-2xl" title="Instagram">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zM5.838 12a6.162 6.162 0 1 1 12.324 0 6.162 6.162 0 0 1-12.324 0zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm4.965-10.322a1.44 1.44 0 1 1 2.881.001 1.44 1.44 0 0 1-2.881-.001z"/></svg>
          </a>
          <a href="https://facebook.com/soullabgym" target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-blue-600 transition-colors text-2xl" title="Facebook">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.youtube.com/channel/UCMGyz96tdBUgD-RG6SyEDRg" target="_blank" rel="noopener noreferrer" class="text-gray-600 hover:text-red-600 transition-colors text-2xl" title="YouTube">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="bg-gradient-to-r from-pink-50 to-green-50 border-t border-gray-200 mt-10 pt-8 pb-8">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <span class="text-gray-700 font-medium">Ready to get started?</span>
        <a href="https://slg.gymdesk.com/login" class="text-gray-700 hover:text-pink-600 font-medium transition-colors border-r border-gray-300 pr-4">
          Login
        </a>
        <a href="https://slg.gymdesk.com/signup" class="bg-gradient-to-r from-pink-500 to-green-400 hover:from-pink-600 hover:to-green-500 text-white font-bold px-6 py-2 rounded-full transition-all">
          Sign Up Now
        </a>
      </div>
    </div>

    <div class="border-t border-gray-200 mt-0 pt-6 text-center text-gray-600 text-sm">
      © 2026 Soul Lab Gym. All rights reserved.
    </div>
  </div>
</footer>
