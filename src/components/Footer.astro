---
---

<footer class="bg-[#080808] text-white/60">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div>
        <div class="flex items-baseline gap-1.5 mb-4">
          <span class="font-display text-3xl text-slg-pink tracking-tight">SOUL LAB</span>
          <span class="font-body text-[10px] font-bold text-white/40 tracking-[0.35em] uppercase">Gym</span>
        </div>
        <p class="text-white/60 text-sm leading-relaxed">
          Townsville's premier Muay Thai gym for families, fighters, and future champions.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-bold text-white mb-4 uppercase tracking-widest text-sm">Quick Links</h3>
        <ul class="space-y-2">
          {[
            { label: 'Home', href: '/' },
            { label: 'Classes', href: '/timetable' },
            { label: 'Private Training', href: '/private-training' },
            { label: 'About', href: '/about' },
            { label: 'Contact', href: '/contact' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-slg-pink transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Programs -->
      <div>
        <h3 class="font-bold text-white mb-4 uppercase tracking-widest text-sm">Programs</h3>
        <ul class="space-y-2">
          {[
            { label: 'Stand Strong', href: '/stand-strong' },
            { label: 'Recovery', href: '/recovery' },
            { label: 'Gallery', href: '/gallery' },
            { label: 'Testimonials', href: '/testimonials' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-white/70 hover:text-slg-pink transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-bold text-white mb-4 uppercase tracking-widest text-sm">Contact</h3>
        <div class="space-y-3">
          <div>
            <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Phone</p>
            <a href="tel:0432558304" class="text-white/60 hover:text-slg-pink transition-colors">
              0432 558 304
            </a>
          </div>
          <div>
            <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Email</p>
            <a href="mailto:info@soullabgym.com" class="text-white/60 hover:text-slg-pink transition-colors">
              info@soullabgym.com
            </a>
          </div>
          <div>
            <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Address</p>
            <p class="text-white/60">2/70 Ingham Road<br />West End, QLD</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Social & Bottom -->
    <div class="border-t border-white/10 pt-8">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-8">
        <!-- Social Links -->
        <div class="flex items-center gap-6">
          <a href="https://facebook.com/soullabgym" target="_blank" rel="noopener" class="text-white/70 hover:text-slg-pink transition-colors">
            <span class="text-sm font-semibold uppercase tracking-wider">Facebook</span>
          </a>
          <a href="https://instagram.com/soul.lab.gym" target="_blank" rel="noopener" class="text-white/70 hover:text-slg-pink transition-colors">
            <span class="text-sm font-semibold uppercase tracking-wider">Instagram</span>
          </a>
          <a href="https://youtube.com/@soullabgym" target="_blank" rel="noopener" class="text-white/70 hover:text-slg-pink transition-colors">
            <span class="text-sm font-semibold uppercase tracking-wider">YouTube</span>
          </a>
        </div>

        <!-- CTA -->
        <a
          href="https://slg.gymdesk.com/signup"
          class="bg-slg-pink hover:bg-slg-pink-hover text-white font-bold text-sm uppercase tracking-wide px-8 py-3 rounded-full transition-colors"
        >
          Start Free Trial
        </a>
      </div>

      <!-- Copyright -->
      <div class="text-center mt-8 pt-8 border-t border-white/10">
        <p class="text-white/40 text-xs">
          © {new Date().getFullYear()} Soul Lab Gym. All rights reserved. <a href="/" class="hover:text-slg-pink transition-colors">Townsville, QLD</a>
        </p>
      </div>
    </div>
  </div>
</footer>
